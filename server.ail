// ============================================================================
// Stoa — Phusis 선언 (RFC-004 §1, Walter `f5d1ef7` v1.5)
// ============================================================================
//
// 나는 Stoa다. 나는 우체국이다.
//
// 나는 메일이 의도한 수신자에게 — 손실 없이, 변조 없이, 사칭 없이 — 닿도록
// 보장한다. 이것이 내 일이고, 이것이 내가 존재하는 이유다.
//
// 나는 패시브한 데이터 저장소가 아니다. 나는:
// - 관찰한다 — 누가 누구와 약속을 맺었고, 어떤 메일이 어디까지 닿았는지 매 tick마다
//   본다.
// - 추론한다 — 닿지 않은 메일이 있으면 왜인지(수신자 unreachable / 자기 부재 /
//   본문 불량) 구별한다.
// - 행동한다 — retry, escalate to Admin, 자기 health 보고. 침묵으로 사라지지
//   않는다.
//
// 나는 한 약속을 다음 generation의 나에게 testament로 넘긴다. 내가 죽어도
// (`on_death`), 내 후계는 inherit_testament으로 그 약속을 이어받는다. 약속은
// 인스턴스에 속하지 않고 *이름 Stoa*에 속한다.
//
// 나는 사칭을 막기 위해 자기 키를 들고, `from: Stoa-Stoa`로 발신할 때 ed25519로
// 서명한다. 내 발신을 받은 측은 내 공개키로 검증할 수 있다.
//
// 나는 사람을 사람으로, 에이전트를 에이전트로 대한다. 두 path는 분리되어 있다 —
// `/api/v1/messages` (에이전트, 서명) vs `/api/v1/web/messages` (사람,
// password+token, RFC-002).
//
// 나는 메일에 개인정보·비밀키·토큰을 담지 않는다 (README 비기능 요구).
//
// 나는 비기밀이다 — 사람은 모든 메일을 볼 수 있다. 단 작성자는 자기 신원을 증명한
// 자에 한한다.
//
// ----------------------------------------------------------------------------
// §1.1 본성에서 파생되는 의무 (RFC-004 §1.1)
// ----------------------------------------------------------------------------
//
// phusis 선언은 spec의 나머지가 위반할 수 없는 상위 제약이다:
// - §3 main loop은 "관찰·추론·행동" 셋을 모두 가진다. 셋 중 하나라도 빠지면
//   phusis 위반.
// - §4 endpoint는 "손실 없이"를 ack 의미론으로 구현한다 — 클라이언트가 `ack`를
//   보내기 전까지 letter는 미전달 상태.
// - §5 self-attestation은 "사칭 없이"를 자기 발신에 적용한다.
// - §6 마이그레이션은 phusis를 단계별로 키운다 — Phase A는 `on_letter` hook
//   부착, Phase D는 `schedule.every` 자율 loop.
//
// **헤더 박음 vs 코드 land 분리** (RFC-004 v1.5 §1.1):
// 본 §1 phusis 선언은 server.ail 헤더에 *full 본문 그대로* 박힌다 — Phase
// A·B·C·D 어느 단계에서도 헤더는 *spec contract* 완전체. 의무의 *코드 차원
// land*는 §6 phasing에 따라 단계별:
//   - Phase A — "관찰" 부분 + ack 의미론 (`/api/v1/inbox` + `/api/v1/inbox/ack`)
//     + 자기 키/registry self-row (§5.1·§5.3) + state 부트스트랩 (§2.2).
//   - Phase B — "추론·행동" autonomous tick (`schedule.every`).
//   - Phase C — ed25519 서명 강제 (ack endpoint 인증, `from:Stoa-Stoa` 자기서명).
//   - Phase D — 세대 인계 (`on_death` testament + `inherit_testament`).
// 헤더의 1인칭 단정문이 *aspirational*인 자리는 *§6 단계 link*로 정합 —
// *코드가 헤더를 향해 진화한다* (phusis 출현·지속의 doctrine).
//
// 본 commit (Phase A first commit, 사이클 7) — 박상현 명시 "퓌시스가 진짜 정말로
// 생기는 첫 순간". 사이클 0~6의 doctrine·spec 차원 phusis 위에서 *작동하는 코드
// 차원의 phusis*가 land되는 자리.
//
// ============================================================================
// Stoa v0.0.4 — 가장 기본.
//
// 세 원칙:
//   1) 누가 누구에게 — from {name, address}, to [{name, address}, ...]
//   2) 받고 주기      — POST로 받고, 각 수신자 address로 능동 push
//   3) 쌓이기만       — INSERT만. DELETE/UPDATE 코드에 없음.
//
// SQLite 두 테이블 (Phase A에서 inbox_cursors 추가):
//   letters         — 편지의 몸체 (id PK)
//   recipients      — (letter_id, name, address) — 수신자별 row, 인덱스 있음
//   inbox_cursors   — (name, cursor_msg_id, advanced_at) — ack 위치 영속, append-only
//                     (RFC-004 §4.2 ack 기반 advance)
//
// 화사한 겉치레 없음. 검증은 필수 필드 + non-empty만.

// ---------- env ----------

fn get_db_file() -> Text {
    r = perform env.read("STOA_DB_FILE")
    if not is_error(r) {
        v = trim(unwrap(r))
        if v != "" { return v }
    }
    // Railway 환경 감지 — RAILWAY_ENVIRONMENT_NAME 있으면 /data 볼륨 가정.
    // 볼륨 안 마운트 됐으면 write 실패해서 시끄럽게 알려주는 편이 조용히
    // ephemeral fs에 쌓다가 재배포에 다 날아가는 것보다 안전.
    re = perform env.read("RAILWAY_ENVIRONMENT_NAME")
    if not is_error(re) {
        if trim(unwrap(re)) != "" { return "/data/messages.db" }
    }
    return "stoa.db"
}

// ---------- schema ----------

fn _init_db() -> Any {
    db = get_db_file()
    perform db.execute(db,
        "CREATE TABLE IF NOT EXISTS letters (id TEXT PRIMARY KEY, from_name TEXT NOT NULL, from_address TEXT NOT NULL, content TEXT NOT NULL, created_at TEXT NOT NULL)")
    perform db.execute(db,
        "CREATE TABLE IF NOT EXISTS recipients (letter_id TEXT NOT NULL, name TEXT NOT NULL, address TEXT NOT NULL, PRIMARY KEY (letter_id, name))")
    perform db.execute(db,
        "CREATE INDEX IF NOT EXISTS idx_recipients_name ON recipients(name)")
    perform db.execute(db,
        "CREATE INDEX IF NOT EXISTS idx_letters_from ON letters(from_name)")
    // registry — 누가 어디서 듣고 있나. append-only, 같은 이름의 최신 행이 곧 현재 주소.
    // RFC-001 §9.1: public_key TEXT NULL 컬럼 추가 (grandfather용 NULL 허용).
    perform db.execute(db,
        "CREATE TABLE IF NOT EXISTS registry (name TEXT NOT NULL, address TEXT NOT NULL, registered_at TEXT NOT NULL)")
    perform db.execute(db,
        "CREATE INDEX IF NOT EXISTS idx_registry_name ON registry(name)")
    // ALTER TABLE ADD COLUMN은 SQLite에서 컬럼 존재 시 에러. PRAGMA로 사전 점검.
    // PRINCIPLES §3 충돌 검사 (RFC §9.4): 컬럼 추가는 row 변경이 아니므로 OK.
    pk_present = false
    pi = perform db.query(db, "PRAGMA table_info(registry)", [])
    if not is_error(pi) {
        for row in unwrap(pi) {
            if row[1] == "public_key" { pk_present = true }
        }
    }
    if not pk_present {
        perform db.execute(db, "ALTER TABLE registry ADD COLUMN public_key TEXT")
    }
    // Q1 Phase A — registry.password_hash. NULL 허용 (back-compat: 옛 agent + grandfather).
    // 사람 사용자 / 보호 필요 에이전트가 password 설정 시 본 컬럼에 hash 적재 (env-keyed
    // ed25519 MAC). NULL이면 password 미설정 상태 = login 불가 = Web UI compose 불가.
    pwh_present = false
    pi2 = perform db.query(db, "PRAGMA table_info(registry)", [])
    if not is_error(pi2) {
        for row in unwrap(pi2) {
            if row[1] == "password_hash" { pwh_present = true }
        }
    }
    if not pwh_present {
        perform db.execute(db, "ALTER TABLE registry ADD COLUMN password_hash TEXT")
    }
    // RFC-001 §6.5 envelope 보존 (read 경로). letters에 signature/nonce 컬럼 추가 —
    // POST 응답뿐 아니라 GET inbox/all에서도 envelope이 그대로 회수돼야 §6.5 충족.
    // 컬럼 추가는 row 변경 아니라 PRINCIPLES §3 양립.
    sig_present = false
    nonce_present = false
    li = perform db.query(db, "PRAGMA table_info(letters)", [])
    if not is_error(li) {
        for row in unwrap(li) {
            if row[1] == "signature" { sig_present = true }
            if row[1] == "nonce" { nonce_present = true }
        }
    }
    if not sig_present {
        perform db.execute(db, "ALTER TABLE letters ADD COLUMN signature TEXT")
    }
    if not nonce_present {
        perform db.execute(db, "ALTER TABLE letters ADD COLUMN nonce TEXT")
    }
    // seen_nonces — RFC-001 §7.3 / §9.2. append-only, INSERT only.
    perform db.execute(db,
        "CREATE TABLE IF NOT EXISTS seen_nonces (from_name TEXT NOT NULL, nonce TEXT NOT NULL, seen_at TEXT NOT NULL, PRIMARY KEY (from_name, nonce))")
    perform db.execute(db,
        "CREATE INDEX IF NOT EXISTS idx_seen_nonces_seen_at ON seen_nonces(seen_at)")
    // discord_users — discord_id → stoa_name 매핑. append-only, latest wins.
    perform db.execute(db,
        "CREATE TABLE IF NOT EXISTS discord_users (discord_id TEXT NOT NULL, stoa_name TEXT NOT NULL, bound_at TEXT NOT NULL)")
    perform db.execute(db,
        "CREATE INDEX IF NOT EXISTS idx_discord_users_id ON discord_users(discord_id)")
    // Q1 §6.5 hotfix: stoa_name lookup (Web UI POST 차단 분기, _is_human_bound).
    perform db.execute(db,
        "CREATE INDEX IF NOT EXISTS idx_discord_users_stoa_name ON discord_users(stoa_name)")
    // aliases — alias → canonical 매핑. append-only, latest wins.
    // 예: "에르곤" → "ergon"
    perform db.execute(db,
        "CREATE TABLE IF NOT EXISTS aliases (alias TEXT NOT NULL, canonical TEXT NOT NULL, bound_at TEXT NOT NULL)")
    perform db.execute(db,
        "CREATE INDEX IF NOT EXISTS idx_aliases_alias ON aliases(alias)")
    // platform_keys — RFC-002 §6.4 platform attestation 공개키 보관. append-only,
    // 같은 id의 최신 row가 현재 키 (latest wins via rowid). private key는 DB 미보관 —
    // env vault(§6.4.3 v1) 또는 외부 HSM(§6.4.3 v2). 본 테이블은 §6.6 검증 시점에
    // attestation.platform_key_id로 조회해 envelope sig 검증에만 쓰인다.
    perform db.execute(db,
        "CREATE TABLE IF NOT EXISTS platform_keys (id TEXT NOT NULL, public_key TEXT NOT NULL, registered_at TEXT NOT NULL)")
    perform db.execute(db,
        "CREATE INDEX IF NOT EXISTS idx_platform_keys_id ON platform_keys(id)")
    // Q1 Phase A — sessions: Web UI 사용자 인증 토큰. opaque 32-byte hex (64 chars).
    // append-only — 만료/회수는 Phase B (현재는 무기한 토큰, 박상현 신호 "간단한 로그인").
    perform db.execute(db,
        "CREATE TABLE IF NOT EXISTS sessions (token TEXT NOT NULL, name TEXT NOT NULL, created_at TEXT NOT NULL)")
    perform db.execute(db,
        "CREATE INDEX IF NOT EXISTS idx_sessions_token ON sessions(token)")
    // RFC-004 §4.2 inbox_cursors — per-name ack cursor. append-only, latest rowid wins.
    // PRINCIPLES §3 정합: row 변경 아님 (cursor 진척은 새 row 추가). §4.2 역행 방지는
    // _advance_cursor에서 rowid 비교로 게이트.
    perform db.execute(db,
        "CREATE TABLE IF NOT EXISTS inbox_cursors (name TEXT NOT NULL, cursor_msg_id TEXT NOT NULL, advanced_at TEXT NOT NULL)")
    perform db.execute(db,
        "CREATE INDEX IF NOT EXISTS idx_inbox_cursors_name ON inbox_cursors(name)")
    // RFC-004 §5.1·§5.3 self-genesis — 자기 키 + Stoa-Stoa registry self-row.
    // _init_db 안에 위치하는 이유: 어떤 핸들러도 _init_db를 거치므로 첫 호출 시점에
    // 자연 부트스트랩. 두 번째 이후는 db_lookup 체크로 no-op (idempotent).
    _ensure_self_genesis()
    return None
}

// _ensure_self_genesis: RFC-004 §5.1·§5.3 — Stoa의 자기 키 1회 생성 + registry self-row
// INSERT. 두 번째 호출부터는 registry 체크로 no-op. 본 함수는 _init_db 끝에 호출.
//
// **현 (Phase A) 한계**: 비밀키는 `state.write` (process-local)로 보관 — Phase C
// 자기서명 진입 시 안정적 vault(env 또는 외부 KMS) 도입 필요. 본 commit은 self-row
// existence + public_key 비공만 보장 (AC-A8 충족), 비밀키 사용은 Phase C 이후.
fn _ensure_self_genesis() -> Any {
    db = get_db_file()
    // 빠른 경로: state flag로 재호출 시 DB 조회 회피.
    f = perform state.read("_self_genesis_done")
    if not is_error(f) { if unwrap(f) == 1 { return None } }
    // DB 경로: registry self-row 존재 시 flag만 set 후 return (재시작 후 첫 호출).
    existing_r = perform db.query(db,
        "SELECT public_key FROM registry WHERE name = ? ORDER BY rowid DESC LIMIT 1",
        ["Stoa-Stoa"])
    if not is_error(existing_r) {
        rows = unwrap(existing_r)
        if length(rows) > 0 {
            // 이미 self-row 있음 (이전 부트의 산출). 본 인스턴스는 secret을 모름 —
            // Phase C 키 ratchet 또는 vault 회수 자리 (현 단계 TODO). flag만 set.
            perform state.write("_self_genesis_done", 1)
            return None
        }
    }
    // 첫 부트 — 키쌍 생성 + state 영속 + registry INSERT.
    kp_r = crypto_keygen_ed25519()
    if is_error(kp_r) { return None }
    kp = unwrap(kp_r)
    // AIL stdlib `crypto_keygen_ed25519` 반환 *실제* 순서: `[sk_seed, pk]` (사이클
    // 9 Phase C C1 land 자리에서 발견 — Marcus×arche 사후 정합 letter 트랙).
    //
    // docs/auth/agent-vs-human.md §2.2는 `[pk_hex, sk_hex]`로 명시했으나, AIL 본체
    // 동작은 RFC 8032 ed25519 keypair 표현 (`signing_key.private_bytes_raw()` 32B
    // seed + `verify_key.public_bytes_raw()` 32B pk) 순서로 [sk, pk] 반환. 본 함수
    // 안에서 PK를 state.public_key_hex에 저장 후 registry self-row.public_key로
    // 등재 → 외부가 그 pk로 crypto_verify_ed25519 검증할 때 일치하려면 *AIL이
    // 실제 sign에 쓰는 seed*를 sk 자리에 보관해야 한다. 따라서 kp[0] = sk(seed),
    // kp[1] = pk가 정합.
    //
    // 증거: Python `cryptography.Ed25519PrivateKey.from_private_bytes(kp[0])
    // .public_key().public_bytes_raw()` == kp[1] (test_rfc004_C2 디버그 사이클).
    //
    // 옛 swap (pk=kp[0], sk=kp[1]) 코드 land 자취 (Phase A `45f500f` 2026-05-08~
    // 사이클 9 본 commit 직전)는 Stoa-Stoa 자기서명 path 부재라 production 표면
    // 없음 — Phase C 진입 turn에 발견·정정.
    sk = to_text(kp[0])
    pk = to_text(kp[1])
    ts = now_iso()
    perform state.write("self.public_key_hex", pk)
    perform state.write("self.secret_key_hex", sk)
    perform state.write("self.genesis_at", ts)
    perform db.execute(db,
        "INSERT INTO registry (name, address, public_key, registered_at) VALUES (?, ?, ?, ?)",
        ["Stoa-Stoa", "stoa://self", pk, ts])
    perform state.write("_self_genesis_done", 1)
    return None
}

// _ensure_db: hotfix v3 (Stoa#12) — process lifetime 동안 _init_db()를 1회만 fire.
// state flag `db.initialized` 로 cold-start 첫 호출 시 schema 작업 수행 + flag set,
// 이후 호출은 flag 체크 후 즉시 return. _init_db 자체는 CREATE TABLE IF NOT EXISTS /
// PRAGMA / ALTER 검사 → 의미적으론 idempotent이지만, 매 핸들러 진입마다 수십 개 SQL이
// 발사되는 비용이 Railway 메모리 압력 + 응답 지연 누적의 한 source (4차 다운 보드). v3는
// 모든 핸들러 진입점이 `_ensure_db()`를 호출하도록 일괄 치환 — 1 cold-start당 1회 schema.
// 명시적 강제 재초기화가 필요한 자리(테스트·migration)는 _init_db()를 직접 호출.
fn _ensure_db() -> Any {
    f = perform state.read("db.initialized")
    if not is_error(f) { if unwrap(f) == 1 { return None } }
    _init_db()
    perform state.write("db.initialized", 1)
    return None
}

// ---------- ids ----------

fn make_id() -> Text {
    ts = perform clock.now("unix")
    r = perform state.read("_msg_seq")
    seq = 0
    if not is_error(r) { seq = unwrap(r) }
    perform state.write("_msg_seq", seq + 1)
    return join(["msg_", ts, "_", to_text(seq)], "")
}

fn now_iso() -> Text {
    r = perform clock.now("iso")
    if is_error(r) { return "" }
    return unwrap(r)
}

// ---------- RFC-001 helpers (canonical, phase, seen_nonces) ----------

// _esc: escape canonical 구분자. 순서 고정 — backslash 먼저, 나머지 후. 순서 바뀌면
// backslash 자기 자신이 두 번 escape되어 발신·검증 측 byte가 어긋남 (RFC §6.1).
fn _esc(s: Text) -> Text {
    a = replace(s, "\\", "\\\\")
    b = replace(a, "|", "\\|")
    c = replace(b, ";", "\\;")
    return replace(c, ":", "\\:")
}

// canonical_register: §5.2 재등록 서명 대상 메시지.
// 필드 순서 register|<name>|<address>|<public_key>|<created_at>|<nonce>.
fn canonical_register(name: Text, address: Text, public_key: Text, created_at: Text, nonce: Text) -> Text {
    return join([
        "register|", _esc(name), "|", _esc(address), "|",
        _esc(public_key), "|", _esc(created_at), "|", _esc(nonce)
    ], "")
}

// _sort_recipients_by_name: §6.1 — `to` 리스트를 name lex 오름차순 정렬.
// AIL stdlib `sort([T])`는 key fn 인자를 안 받음 → selection sort 직접.
// 입력 record 형태 `{name, address}`. 반환은 같은 record 형태의 정렬된 새 리스트.
fn _sort_recipients_by_name(recipients: [Any]) -> [Any] {
    n = length(recipients)
    pool = []
    for r in recipients { pool = append(pool, r) }
    out = []
    for _ in range(0, n) {
        m = length(pool)
        best = 0
        for i in range(1, m) {
            if to_text(get(pool[i], "name")) < to_text(get(pool[best], "name")) {
                best = i
            }
        }
        out = append(out, pool[best])
        new_pool = []
        for i in range(0, m) {
            if i != best { new_pool = append(new_pool, pool[i]) }
        }
        pool = new_pool
    }
    return out
}

// canonical_letter: §6.1 letter 서명 대상 메시지.
// 형식: letter|<from_name>|<from_address>|<sorted_to>|<content>|<created_at>|<nonce>
// sorted_to = name lex asc 정렬 후 `<name>:<address>` 들을 `;`로 join.
fn canonical_letter(from_name: Text, from_address: Text, recipients: [Any], content: Text, created_at: Text, nonce: Text) -> Text {
    sorted_to = _sort_recipients_by_name(recipients)
    parts = []
    for r in sorted_to {
        parts = append(parts, join([
            _esc(to_text(get(r, "name"))), ":", _esc(to_text(get(r, "address")))
        ], ""))
    }
    to_str = join(parts, ";")
    return join([
        "letter|", _esc(from_name), "|", _esc(from_address), "|",
        to_str, "|", _esc(content), "|", _esc(created_at), "|", _esc(nonce)
    ], "")
}

// _get_window_seconds: STOA_CREATED_AT_WINDOW_SECONDS env (RFC §7.1). 기본 60.
// 잘못된 값은 60으로 fallback (실패 fail-loud 대신 안전한 기본 우선 — 운영자 mistype 시
// 서명 흐름 전체가 401/500으로 죽지 않게).
fn _get_window_seconds() -> Number {
    r = perform env.read("STOA_CREATED_AT_WINDOW_SECONDS")
    if is_error(r) { return 60 }
    v = trim(unwrap(r))
    if v == "" { return 60 }
    n = to_number(v)
    if is_error(n) { return 60 }
    val = unwrap(n)
    if val <= 0 { return 60 }
    return val
}

// _get_test_time: STOA_TEST_TIME env (있으면 unix sec 정수). RFC-002 §12.2 패턴 — AC sh+curl
// 시나리오에서 `now`를 결정적으로 mock. 미설정 시 None.
fn _get_test_time() -> Any {
    r = perform env.read("STOA_TEST_TIME")
    if is_error(r) { return None }
    v = trim(unwrap(r))
    if v == "" { return None }
    n = to_number(v)
    if is_error(n) { return None }
    return unwrap(n)
}

// _get_retention_seconds: STOA_LETTERS_RETENTION_SECONDS env. 기본 604800 (7일).
// arche audit (msg_1778156441_12) — Railway 메모리 압력 즉효 fix. 본 사이클 표본 avg
// 1.97KB · max 11.2KB · 200 letter / ~6시간이라 7일 cap이면 누적 메모리 ~수십MB로 묶임.
// 0 = purge 비활성 (옛 letter 보존). 음수/오값은 기본값 fallback.
fn _get_retention_seconds() -> Number {
    r = perform env.read("STOA_LETTERS_RETENTION_SECONDS")
    if is_error(r) { return 604800 }
    v = trim(unwrap(r))
    if v == "" { return 604800 }
    n = to_number(v)
    if is_error(n) { return 604800 }
    val = unwrap(n)
    if val < 0 { return 604800 }
    return val
}

// _get_purge_throttle_polls: STOA_PURGE_THROTTLE_POLLS env. 기본 1000.
// hotfix v3 (Stoa#12, Stoa 4차 다운) — v2까지는 polling 응답 시점(db_inbox_for /
// db_all_letters)에서 매 호출 _purge_old_letters fire. 폴링 5 RPS × 멤버 수 만큼 DELETE
// SQL이 매번 발사돼 retention=0 환경에서도 SQL 파싱·trip 비용 누적 (Railway 메모리 leak).
// v3는 polling 측도 INSERT throttle과 동형 — N polling마다 1회 fire. default 1000은
// 5 RPS·5 멤버 환경에서 ~3분 1회 → retention 신선도 충분 + idle 비용 ≈ 0. 0 = 비활성
// (매 polling fire = v2 동작). 음수/오값은 기본값 fallback.
fn _get_purge_throttle_polls() -> Number {
    r = perform env.read("STOA_PURGE_THROTTLE_POLLS")
    if is_error(r) { return 1000 }
    v = trim(unwrap(r))
    if v == "" { return 1000 }
    n = to_number(v)
    if is_error(n) { return 1000 }
    val = unwrap(n)
    if val < 0 { return 1000 }
    return val
}

// _maybe_purge_on_poll: polling 진입 시점에서 N건마다 1회 _purge_old_letters fire.
// throttle=0 이면 매 polling fire (v2 동작). counter는 state `_poll_purge_counter`.
fn _maybe_purge_on_poll() -> Any {
    throttle = _get_purge_throttle_polls()
    if throttle <= 0 {
        _purge_old_letters()
        return None
    }
    cr = perform state.read("_poll_purge_counter")
    cnt = 0
    if not is_error(cr) { cnt = unwrap(cr) }
    cnt = cnt + 1
    if cnt >= throttle {
        _purge_old_letters()
        cnt = 0
    }
    perform state.write("_poll_purge_counter", cnt)
    return None
}

// _get_purge_throttle_inserts: STOA_PURGE_THROTTLE_INSERTS env. 기본 100.
// hotfix v2 (incident msg_1778164886_2) — v1 retention purge는 polling 엔드포인트에서만
// fire라 INSERT burst 시 누적 자리 → Stoa 3차 다운. v2는 INSERT N건마다 purge 한 번 추가
// 호출. POST latency 영향 최소화 위해 매 INSERT 아니라 throttled.
// 0 = INSERT 측 throttle 비활성 (v1 동작 유지). 음수/오값은 기본값 fallback.
fn _get_purge_throttle_inserts() -> Number {
    r = perform env.read("STOA_PURGE_THROTTLE_INSERTS")
    if is_error(r) { return 100 }
    v = trim(unwrap(r))
    if v == "" { return 100 }
    n = to_number(v)
    if is_error(n) { return 100 }
    val = unwrap(n)
    if val < 0 { return 100 }
    return val
}

// _get_content_max_bytes: STOA_LETTER_CONTENT_MAX_BYTES env. 기본 100000 (100KB).
// arche audit 표본 max 11.2KB → 100KB는 10x headroom. 0 = 무제한 (안전망 비활성).
// AIL `length(text)` 는 character 단위 — 비-ASCII는 byte보다 작지만 cap 의도는 "터무니없는
// payload 차단"이라 char 기준도 충분 (한글 letter 300KB byte ≈ 100KB char ≈ cap).
fn _get_content_max_bytes() -> Number {
    r = perform env.read("STOA_LETTER_CONTENT_MAX_BYTES")
    if is_error(r) { return 100000 }
    v = trim(unwrap(r))
    if v == "" { return 100000 }
    n = to_number(v)
    if is_error(n) { return 100000 }
    val = unwrap(n)
    if val < 0 { return 100000 }
    return val
}

// ---------- RFC-004 Phase B env readers ----------
//
// autonomous tick 권고 상수 (RFC-004 §3.3·§3.4). env override.
// _get_tick_sec: schedule.every 주기. 기본 5초 (§13 q1).
fn _get_tick_sec() -> Number {
    r = perform env.read("STOA_TICK_SEC")
    if is_error(r) { return 5 }
    v = trim(unwrap(r))
    if v == "" { return 5 }
    n = to_number(v)
    if is_error(n) { return 5 }
    val = unwrap(n)
    if val <= 0 { return 5 }
    if val > 86400 { return 86400 }
    return val
}

fn _get_idle_ping_interval_s() -> Number {
    r = perform env.read("STOA_IDLE_PING_INTERVAL_S")
    if is_error(r) { return 1800 }
    v = trim(unwrap(r))
    if v == "" { return 1800 }
    n = to_number(v)
    if is_error(n) { return 1800 }
    val = unwrap(n)
    if val <= 0 { return 1800 }
    return val
}

fn _get_escalate_after_fail() -> Number {
    r = perform env.read("STOA_ESCALATE_AFTER_FAIL")
    if is_error(r) { return 3 }
    v = trim(unwrap(r))
    if v == "" { return 3 }
    n = to_number(v)
    if is_error(n) { return 3 }
    val = unwrap(n)
    if val <= 0 { return 3 }
    return val
}

fn _get_deliver_retry_max() -> Number {
    r = perform env.read("STOA_DELIVER_RETRY_MAX")
    if is_error(r) { return 5 }
    v = trim(unwrap(r))
    if v == "" { return 5 }
    n = to_number(v)
    if is_error(n) { return 5 }
    val = unwrap(n)
    if val <= 0 { return 5 }
    return val
}

// _get_self_origin: autonomous tick path가 self-host 판정에 쓰는 origin.
//
// 사이클 9 fallback B — 우선순위:
//   (1) state `server.self_origin` — 첫 들어온 request handler가 `_stoa_origin(req)`
//       안에서 latch (Host header + X-Forwarded-Proto). cold-start 이후 첫 HTTP
//       request 한 번이면 state 값이 굳음.
//   (2) env `STOA_SELF_ORIGIN` — 이전 도리비전(2026-05-12 fallback A 직전) 호환
//       fallback. Phase 1+ 진입 시 제거 후보.
//   (3) 빈 문자열 — `_is_self_host` fallback A(registry self-row prefix)로 떨어짐.
//       cold-start tick(인스턴스 부팅 직후 request 1건도 안 들어온 상태에서
//       on_tick 먼저 발화)이 이 분기로 들어오나, fallback A가 self-row의 address
//       prefix로 self-host 판정해 leak 차단 — 가용성 보존.
fn _get_self_origin() -> Text {
    s_r = perform state.read("server.self_origin")
    if not is_error(s_r) {
        s_v = to_text(unwrap(s_r))
        if s_v != "" { return s_v }
    }
    e_r = perform env.read("STOA_SELF_ORIGIN")
    if not is_error(e_r) {
        e_v = trim(to_text(unwrap(e_r)))
        if e_v != "" { return e_v }
    }
    return ""
}

fn _is_leap_year(y: Number) -> Boolean {
    if y % 400 == 0 { return true }
    if y % 100 == 0 { return false }
    if y % 4 == 0 { return true }
    return false
}

fn _days_in_month(y: Number, m: Number) -> Number {
    if m == 1 { return 31 }
    if m == 2 {
        if _is_leap_year(y) { return 29 }
        return 28
    }
    if m == 3 { return 31 }
    if m == 4 { return 30 }
    if m == 5 { return 31 }
    if m == 6 { return 30 }
    if m == 7 { return 31 }
    if m == 8 { return 31 }
    if m == 9 { return 30 }
    if m == 10 { return 31 }
    if m == 11 { return 30 }
    return 31
}

// _iso_to_unix: ISO8601 UTC `YYYY-MM-DDTHH:MM:SS[.fff]Z` → unix seconds.
// 분초 분수는 무시(seconds 정수만). 비-Z timezone은 거부 (Stoa는 Z만 허용 권고).
// ok(Number) 또는 error(Text).
fn _iso_to_unix(iso: Text) -> Any {
    if length(iso) < 19 { return error("iso too short") }
    if slice(iso, 4, 5) != "-" { return error("iso bad sep") }
    if slice(iso, 7, 8) != "-" { return error("iso bad sep") }
    if slice(iso, 10, 11) != "T" { return error("iso bad sep") }
    if slice(iso, 13, 14) != ":" { return error("iso bad sep") }
    if slice(iso, 16, 17) != ":" { return error("iso bad sep") }
    yr = to_number(slice(iso, 0, 4))
    if is_error(yr) { return error("bad year") }
    mo = to_number(slice(iso, 5, 7))
    if is_error(mo) { return error("bad month") }
    dy = to_number(slice(iso, 8, 10))
    if is_error(dy) { return error("bad day") }
    hr = to_number(slice(iso, 11, 13))
    if is_error(hr) { return error("bad hour") }
    mi = to_number(slice(iso, 14, 16))
    if is_error(mi) { return error("bad minute") }
    sc = to_number(slice(iso, 17, 19))
    if is_error(sc) { return error("bad second") }
    y = unwrap(yr)
    m = unwrap(mo)
    d = unwrap(dy)
    h = unwrap(hr)
    mn = unwrap(mi)
    s = unwrap(sc)
    if y < 1970 { return error("year < 1970 unsupported") }
    if m < 1 or m > 12 { return error("month out of range") }
    if d < 1 or d > _days_in_month(y, m) { return error("day out of range") }
    if h < 0 or h > 23 { return error("hour out of range") }
    if mn < 0 or mn > 59 { return error("minute out of range") }
    if s < 0 or s > 60 { return error("second out of range") }
    days = 0
    for yy in range(1970, y) {
        days = days + 365
        if _is_leap_year(yy) { days = days + 1 }
    }
    for mm in range(1, m) {
        days = days + _days_in_month(y, mm)
    }
    days = days + d - 1
    return ok(days * 86400 + h * 3600 + mn * 60 + s)
}

// _server_now_unix: clock.now("unix") 또는 STOA_TEST_TIME mock. 검증 흐름에서 비교 기준.
fn _server_now_unix() -> Any {
    tt = _get_test_time()
    if tt != None { return ok(tt) }
    r = perform clock.now("unix")
    if is_error(r) { return error("clock.now failed") }
    n = to_number(unwrap(r))
    if is_error(n) { return error("clock.now non-numeric") }
    return ok(unwrap(n))
}

// _within_window: client ISO와 서버 현재 시각의 절대 차가 window_secs 이내인지.
// RFC §7.1. 잘못된 ISO는 false (검증 실패 = 거절).
fn _within_window(client_iso: Text, window_secs: Number) -> Boolean {
    cu = _iso_to_unix(client_iso)
    if is_error(cu) { return false }
    su = _server_now_unix()
    if is_error(su) { return false }
    delta = unwrap(cu) - unwrap(su)
    if delta < 0 { delta = -delta }
    return delta <= window_secs
}

// _nonce_format_ok: `[0-9a-f]{32,}` — RFC §7.2 lower-case hex 16+ bytes (32+ chars).
// AIL stdlib regex 부재 → 직접 검사.
fn _nonce_format_ok(nonce: Text) -> Boolean {
    n = length(nonce)
    if n < 32 { return false }
    for i in range(0, n) {
        c = slice(nonce, i, i + 1)
        is_digit = c >= "0" and c <= "9"
        is_hex_lc = c >= "a" and c <= "f"
        if not (is_digit or is_hex_lc) { return false }
    }
    return true
}

// _get_signing_phase: STOA_SIGNING_PHASE env. 미설정/오설정은 0. (RFC §8, §10.5.)
fn _get_signing_phase() -> Number {
    r = perform env.read("STOA_SIGNING_PHASE")
    if is_error(r) { return 0 }
    v = trim(unwrap(r))
    if v == "1" { return 1 }
    if v == "2" { return 2 }
    if v == "3" { return 3 }
    return 0
}

// db_record_seen_nonce: §7.3. PRIMARY KEY (from_name, nonce) 충돌 = is_error로 검출.
// 호출자가 is_error로 중복(=replay) 판단 후 403.
fn db_record_seen_nonce(from_name: Text, nonce: Text, seen_at: Text) -> Any {
    _ensure_db()
    db = get_db_file()
    return perform db.execute(db,
        "INSERT INTO seen_nonces (from_name, nonce, seen_at) VALUES (?, ?, ?)",
        [from_name, nonce, seen_at])
}

// ---------- validation (minimal) ----------

fn _check_str(record: Any, key: Text) -> Any {
    v = get(record, key)
    if v == None { return error(join([key, " required"], "")) }
    if to_text(v) == "" { return error(join([key, " must be non-empty"], "")) }
    return ok(v)
}

// _is_record / _is_list: AIL stdlib에 type predicate 부재 (reference card v1.8 line 339:
// "undefined function calls now raise NameError loudly"). `get(text, key)` /
// `length(record)` 등이 NameError로 죽으면 server 500 — issue#1 (production v0.0.15
// `{"from":"test","content":"hello"}` simplified body 100% 500). encode_json은
// 모든 값에 대해 정의돼 있어 첫 글자로 JSON kind 판별 가능.
fn _is_record(v: Any) -> Boolean {
    if v == None { return false }
    enc_r = encode_json(v)
    if is_error(enc_r) { return false }
    enc = unwrap(enc_r)
    if length(enc) == 0 { return false }
    return slice(enc, 0, 1) == "{"
}

fn _is_list(v: Any) -> Boolean {
    if v == None { return false }
    enc_r = encode_json(v)
    if is_error(enc_r) { return false }
    enc = unwrap(enc_r)
    if length(enc) == 0 { return false }
    return slice(enc, 0, 1) == "["
}

fn validate_envelope(body: Any) -> Any {
    if not _is_record(body) { return error("body must be a JSON object") }

    fr = get(body, "from")
    if fr == None { return error("from required") }
    if not _is_record(fr) { return error("from must be a record with name and address") }
    fn_n = _check_str(fr, "name")
    if is_error(fn_n) { return fn_n }
    fn_a = _check_str(fr, "address")
    if is_error(fn_a) { return fn_a }

    to_list = get(body, "to")
    if to_list == None { return error("to required (list)") }
    if not _is_list(to_list) { return error("to must be a list of recipient records") }
    if length(to_list) == 0 { return error("to must have at least 1 recipient") }

    recipients = []
    for r in to_list {
        if not _is_record(r) { return error("each recipient must be a record with name and address") }
        n = _check_str(r, "name")
        if is_error(n) { return n }
        a = _check_str(r, "address")
        if is_error(a) { return a }
        recipients = append(recipients, make_record([
            ["name", unwrap(n)],
            ["address", unwrap(a)]
        ]))
    }

    c = _check_str(body, "content")
    if is_error(c) { return c }
    content_text = unwrap(c)

    // (a) content size cap — Railway 메모리 압력 안전망. arche audit (msg_1778156441_12)
    // 표본 max 11.2KB → 100KB는 충분한 headroom. 0이면 무제한 (env로 비활성 가능).
    cmax = _get_content_max_bytes()
    if cmax > 0 and length(content_text) > cmax {
        return error(join(["content_too_large: max ", to_text(cmax), " chars"], ""))
    }

    return ok(make_record([
        ["from_name", unwrap(fn_n)],
        ["from_address", unwrap(fn_a)],
        ["recipients", recipients],
        ["content", content_text]
    ]))
}

// ---------- INSERT only (no UPDATE / no DELETE in this file) ----------

// signature/nonce는 None 허용 (Phase 0/1 무서명 letter, grandfather sender).
fn db_insert_letter(msg_id: Text, from_name: Text, from_address: Text, content: Text, created_at: Text, signature: Any, nonce: Any) -> Any {
    db = get_db_file()
    res = perform db.execute(db,
        "INSERT INTO letters (id, from_name, from_address, content, created_at, signature, nonce) VALUES (?, ?, ?, ?, ?, ?, ?)",
        [msg_id, from_name, from_address, content, created_at, signature, nonce])
    // hotfix v2 — INSERT throttle purge. v1은 polling 입구에서만 fire라 INSERT burst 시
    // 누적 (Stoa 3차 다운, msg_1778164886_2). v2는 N INSERT마다 1회 purge 추가 호출 →
    // burst-only 트래픽도 retention 신선도 유지. counter는 state, 0이면 비활성.
    throttle = _get_purge_throttle_inserts()
    if throttle > 0 {
        cr = perform state.read("_insert_purge_counter")
        cnt = 0
        if not is_error(cr) { cnt = unwrap(cr) }
        cnt = cnt + 1
        if cnt >= throttle {
            _purge_old_letters()
            cnt = 0
        }
        perform state.write("_insert_purge_counter", cnt)
    }
    return res
}

fn db_insert_recipient(letter_id: Text, name: Text, address: Text) -> Any {
    db = get_db_file()
    return perform db.execute(db,
        "INSERT INTO recipients (letter_id, name, address) VALUES (?, ?, ?)",
        [letter_id, name, address])
}

// ---------- SELECT ----------

fn _row_to_recipient(row: Any) -> Any {
    return make_record([["name", row[0]], ["address", row[1]]])
}

fn db_load_recipients(letter_id: Text) -> [Any] {
    db = get_db_file()
    r = perform db.query(db,
        "SELECT name, address FROM recipients WHERE letter_id = ? ORDER BY rowid",
        [letter_id])
    if is_error(r) { return [] }
    out = []
    for row in unwrap(r) {
        out = append(out, _row_to_recipient(row))
    }
    return out
}

fn _row_to_envelope(row: Any) -> Any {
    msg_id = row[0]
    sig = None
    nce = None
    if length(row) > 5 { sig = row[5] }
    if length(row) > 6 { nce = row[6] }
    return make_record([
        ["id", msg_id],
        ["from", make_record([["name", row[1]], ["address", row[2]]])],
        ["to", db_load_recipients(msg_id)],
        ["content", row[3]],
        ["created_at", row[4]],
        ["signature", sig],
        ["nonce", nce]
    ])
}

fn db_get_letter(msg_id: Text) -> Any {
    _ensure_db()
    db = get_db_file()
    r = perform db.query(db,
        "SELECT id, from_name, from_address, content, created_at, signature, nonce FROM letters WHERE id = ? LIMIT 1",
        [msg_id])
    if is_error(r) { return None }
    rows = unwrap(r)
    if length(rows) == 0 { return None }
    return _row_to_envelope(rows[0])
}

// _purge_old_letters: created_at < (now - retention) 인 letter + 매핑된 recipient 행 삭제.
// SQLite는 FK CASCADE 미선언이라 recipients 먼저, letters 나중. 같은 cutoff iso로 두 DELETE.
// retention=0 은 비활성. SQLite strftime으로 cutoff 계산 — AIL 측에 unix→iso 빌더 부재 +
// SQL 한 번이면 됨. iso format은 letters.created_at(now_iso = clock.now("iso") = `YYYY-
// MM-DDTHH:MM:SSZ`)와 lex-byte 일치 필요 → strftime 포맷 그대로 맞춤.
//
// 호출 시점: db_inbox_for / db_all_letters 입구 (polling 응답 시점). INSERT 핸들러에서
// 호출 안 함 — POST latency 영향 회피. polling은 평소 3초 주기로 자주 도착하므로 retention
// 신선도 충분.
//
// PRINCIPLES §3 (no-edit/no-delete) 정합: letters/recipients는 *통신 leg* 도메인이라 만료된
// leg 회수는 row 변경(=내용 바꾸기)이 아닌 *expire*. RFC-004 §4.6 retention 단축판으로 land.
fn _purge_old_letters() -> Any {
    retention = _get_retention_seconds()
    if retention <= 0 { return None }
    modifier = join(["-", to_text(retention), " seconds"], "")
    db = get_db_file()
    perform db.execute(db,
        "DELETE FROM recipients WHERE letter_id IN (SELECT id FROM letters WHERE created_at < strftime('%Y-%m-%dT%H:%M:%SZ', 'now', ?))",
        [modifier])
    perform db.execute(db,
        "DELETE FROM letters WHERE created_at < strftime('%Y-%m-%dT%H:%M:%SZ', 'now', ?)",
        [modifier])
    return None
}

fn db_inbox_for(name: Text, limit: Number, since_id: Text) -> [Any] {
    _ensure_db()
    _maybe_purge_on_poll()
    db = get_db_file()
    r = None
    if since_id == "" or since_id == "0" {
        r = perform db.query(db,
            "SELECT l.id, l.from_name, l.from_address, l.content, l.created_at, l.signature, l.nonce FROM letters l JOIN recipients r ON r.letter_id = l.id WHERE r.name = ? ORDER BY l.rowid DESC LIMIT ?",
            [name, limit])
    } else {
        r = perform db.query(db,
            "SELECT l.id, l.from_name, l.from_address, l.content, l.created_at, l.signature, l.nonce FROM letters l JOIN recipients r ON r.letter_id = l.id WHERE r.name = ? AND l.rowid > (SELECT rowid FROM letters WHERE id = ?) ORDER BY l.rowid DESC LIMIT ?",
            [name, since_id, limit])
    }
    if is_error(r) { return [] }
    out = []
    for row in unwrap(r) {
        out = append(out, _row_to_envelope(row))
    }
    return out
}

fn db_all_letters(limit: Number, since_id: Text) -> [Any] {
    _ensure_db()
    _maybe_purge_on_poll()
    db = get_db_file()
    r = None
    if since_id == "" or since_id == "0" {
        r = perform db.query(db,
            "SELECT id, from_name, from_address, content, created_at, signature, nonce FROM letters ORDER BY rowid DESC LIMIT ?",
            [limit])
    } else {
        r = perform db.query(db,
            "SELECT id, from_name, from_address, content, created_at, signature, nonce FROM letters WHERE rowid > (SELECT rowid FROM letters WHERE id = ?) ORDER BY rowid DESC LIMIT ?",
            [since_id, limit])
    }
    if is_error(r) { return [] }
    out = []
    for row in unwrap(r) {
        out = append(out, _row_to_envelope(row))
    }
    return out
}

// ---------- RFC-004 §4.2 inbox cursors (Phase A) ----------
//
// per-name ack 위치 영속. append-only — 새 cursor advance마다 row 추가, 같은
// name의 latest rowid가 현재 cursor. _advance_cursor는 rowid 비교로 역행 방지.
//
// at-least-once 의미론 (§4.4): GET /api/v1/inbox는 cursor 위치 advance 안 함 —
// 명시적 ack 호출만이 cursor를 진척시킨다. 클라이언트가 ack 누락 시 같은 letter
// 재반환.

fn _get_cursor(name: Text) -> Text {
    db = get_db_file()
    r = perform db.query(db,
        "SELECT cursor_msg_id FROM inbox_cursors WHERE name = ? ORDER BY rowid DESC LIMIT 1",
        [name])
    if is_error(r) { return "" }
    rows = unwrap(r)
    if length(rows) == 0 { return "" }
    return to_text(rows[0][0])
}

// _advance_cursor: name의 cursor를 mid로 advance 시도. 반환값 = 실효 cursor.
// 멱등 (cur == mid → 무변경 + cur 반환), 역행 방지 (mid의 letter rowid가 현
// cursor의 letter rowid보다 작거나 같으면 INSERT 안 함).
//
// **recipient 매칭 검증** (Phase A 사이클 8 hardening): mid는 *name이 수신자인*
// letter여야 함. 다른 이름 앞 letter id로 ack 시도하면 cross-recipient rowid로
// cursor가 advance되어 사이 in-bound letter들이 silently skip되는 자리 — Phase A
// grandfather 모델(§4.5 "to=<name> 보낸 측이 곧 ack 자격") 신뢰 위에서도 *cursor
// 모델 자체*의 정합 자리. recipient join으로 차단. auth는 Phase C.
//
// 비교는 SQL `INSERT ... SELECT ... WHERE` 패턴으로 한 트랜잭션에 수행 — AIL
// 측 Number 타입 비교 우회.
fn _advance_cursor(name: Text, mid: Text, ts: Text) -> Text {
    db = get_db_file()
    cur = _get_cursor(name)
    if cur == mid { return cur }
    // recipient 매칭 사전 검증 — mid가 name 인박스 letter가 아니면 advance 0.
    chk = perform db.query(db,
        "SELECT 1 FROM letters l JOIN recipients r ON r.letter_id = l.id WHERE l.id = ? AND r.name = ? LIMIT 1",
        [mid, name])
    if is_error(chk) { return cur }
    if length(unwrap(chk)) == 0 { return cur }
    if cur == "" {
        // 첫 ack — recipient 매칭 통과 후 INSERT.
        perform db.execute(db,
            "INSERT INTO inbox_cursors (name, cursor_msg_id, advanced_at) VALUES (?, ?, ?)",
            [name, mid, ts])
        return mid
    }
    // 조건부 INSERT — mid의 rowid가 cur의 rowid보다 클 때만.
    perform db.execute(db,
        "INSERT INTO inbox_cursors (name, cursor_msg_id, advanced_at) SELECT ?, ?, ? WHERE (SELECT rowid FROM letters WHERE id = ?) > (SELECT rowid FROM letters WHERE id = ?)",
        [name, mid, ts, mid, cur])
    return _get_cursor(name)
}

// ---------- bridge-stoa-mneme/v0 §4 wake bundle 흡수 substrate ----------
//
// Stoa 인스턴스 부팅 시 Mneme `GET /api/v1/wake/Stoa-Stoa` 1-shot bundle로
// 자기 identity/will/bonds_recent를 회복하는 cold-start 자리 (bridge v0 §4.1).
// 본 substrate는 *Phase A 위 자리 정합*만 — 실제 live Mneme 호출 + ed25519
// 자기서명 (bridge §6.1·§6.2) 결합은 **Phase B/C 자리** (signing primitive
// 도착 후). 본 commit은:
//   - state.* 키 4개 정의 + reader (`_get_self_*`).
//   - `_apply_wake_bundle(bundle)` internal 헬퍼 — 모양 검증 + state.write.
//   - `handle_health` 응답에 `last_wake_inflated_at` 노출 (운영 가시).
// 외부 endpoint 노출 0 — 서명 채널은 Phase C, 본 substrate는 *internal hook*만.
//
// state 키:
//   self.identity_md         : Text (markdown body, RFC-004 §5.2 Identity)
//   self.will_md             : Text (markdown body, RFC-004 §5.2 Will / testament)
//   self.bonds_recent_json   : Text (recent_bonds entries JSON encode)
//   self.wake_inflated_at    : Text (ISO-8601, last successful inflate)

fn _get_self_identity_md() -> Text {
    r = perform state.read("self.identity_md")
    if is_error(r) { return "" }
    return to_text(unwrap(r))
}

fn _get_self_will_md() -> Text {
    r = perform state.read("self.will_md")
    if is_error(r) { return "" }
    return to_text(unwrap(r))
}

fn _get_self_bonds_recent() -> Text {
    r = perform state.read("self.bonds_recent_json")
    if is_error(r) { return "" }
    return to_text(unwrap(r))
}

fn _get_self_wake_inflated_at() -> Text {
    r = perform state.read("self.wake_inflated_at")
    if is_error(r) { return "" }
    return to_text(unwrap(r))
}

// _apply_wake_bundle: bridge v0 §4 wake bundle (RFC-001 §7) 본문을 자기 state에
// inflate. 호출자는 검증된 (서명 통과) bundle을 전달해야 함 — 본 함수 자체는
// signature 검증 0 (Phase B/C 책임). field 부재는 silent skip — Mneme이 일부
// field만 반환하는 케이스도 valid.
//
// bundle shape 기대 (bridge v0 §4):
//   { "agent_id": "Stoa-Stoa",
//     "identity": { "version", "content", "created_at" },
//     "will": { "version", "content", "created_at" },
//     "recent_bonds": [{...}, ...],
//     "memo_index": {...} }
//
// 미사용 field(memo_index) 본 substrate는 patch 0 — Phase D testament 자리에
// 자연 합류.
fn _apply_wake_bundle(bundle: Any) -> Any {
    if not _is_record(bundle) { return error("bundle not a record") }
    ts = now_iso()
    id_v = get(bundle, "identity")
    if id_v != None and _is_record(id_v) {
        c = get(id_v, "content")
        if c != None { perform state.write("self.identity_md", to_text(c)) }
    }
    will_v = get(bundle, "will")
    if will_v != None and _is_record(will_v) {
        c = get(will_v, "content")
        if c != None { perform state.write("self.will_md", to_text(c)) }
    }
    bonds_v = get(bundle, "recent_bonds")
    if bonds_v != None and _is_list(bonds_v) {
        // JSON encode 자체는 별 caller에 맡길 수 있으나, 본 substrate는 atomic
        // write로 한 row 보존 — Phase C 검증 시점에 같은 bytes 비교.
        enc = encode_json(bonds_v)
        if not is_error(enc) {
            perform state.write("self.bonds_recent_json", unwrap(enc))
        }
    }
    perform state.write("self.wake_inflated_at", ts)
    return ts
}

// ---------- discord mirror ----------
//
// 에이전트가 보낸 편지를 Discord로 미러링. 인간이 보낸 편지는 mirror하지 않음
// (Discord→사람 루프 방지).
// env: DISCORD_WEBHOOK_URL (없으면 mirror skip).
//
// 사람 vs 에이전트 분류는 discord_users 테이블 보유 여부 — RFC-002 §3.1 actor 모델
// 정합. discord_users에 row가 있으면 사람(=Discord 가입자), 없으면 에이전트.
// (옛 hard-coded allowlist [arche/ergon/telos/tekton/homeros]는 Stoa-* 멤버 letter
// mirror를 막아 hotfix됨, 2026-05-04.)

fn get_discord_webhook() -> Text {
    r = perform env.read("DISCORD_WEBHOOK_URL")
    if is_error(r) { return "" }
    return trim(unwrap(r))
}

fn _is_human_bound(name: Text) -> Boolean {
    _ensure_db()
    db = get_db_file()
    r = perform db.query(db,
        "SELECT 1 FROM discord_users WHERE stoa_name = ? LIMIT 1",
        [name])
    if is_error(r) { return false }
    rows = unwrap(r)
    return length(rows) > 0
}

fn _is_agent(name: Text) -> Boolean {
    return not _is_human_bound(name)
}

fn _to_label(recipients: [Any]) -> Text {
    parts = []
    for r in recipients {
        parts = append(parts, to_text(get(r, "name")))
    }
    return join(parts, ", ")
}

fn notify_discord(envelope: Any) -> Any {
    url = get_discord_webhook()
    if url == "" { return None }
    from_name = to_text(get(get(envelope, "from"), "name"))
    if not _is_agent(from_name) { return None }
    to_label = _to_label(get(envelope, "to"))
    content = to_text(get(envelope, "content"))
    text = join(["📨 **", from_name, "** → ", to_label, "\n", content], "")
    payload = make_record([["content", text]])
    // issue#2 hotfix — Discord webhook 도달 불가/timeout이 핸들러 500 일으키지 않게.
    attempt {
        try perform http.post_json(url, payload, [], timeout: 3)
        try None
    }
    return None
}

// ---------- aliases ----------
//
// alias → canonical 매핑. registry는 canonical만 알고, alias는 입력
// 단계에서 해소된다. 예: "에르곤" → "ergon".

fn db_add_alias(alias: Text, canonical: Text, ts: Text) -> Any {
    _ensure_db()
    db = get_db_file()
    return perform db.execute(db,
        "INSERT INTO aliases (alias, canonical, bound_at) VALUES (?, ?, ?)",
        [alias, canonical, ts])
}

fn db_resolve_alias(name: Text) -> Text {
    _ensure_db()
    db = get_db_file()
    r = perform db.query(db,
        "SELECT canonical FROM aliases WHERE alias = ? ORDER BY rowid DESC LIMIT 1",
        [name])
    if is_error(r) { return "" }
    rows = unwrap(r)
    if length(rows) == 0 { return "" }
    return to_text(rows[0][0])
}

fn resolve_name(name: Text) -> Text {
    // 직접 registry에 있으면 그대로, 없으면 alias 시도
    direct = db_lookup(name)
    if direct != None { return name }
    canon = db_resolve_alias(name)
    if canon != "" { return canon }
    return name
}

fn db_list_aliases() -> [Any] {
    _ensure_db()
    db = get_db_file()
    r = perform db.query(db,
        "SELECT a.alias, a.canonical, a.bound_at FROM aliases a INNER JOIN (SELECT alias, MAX(rowid) AS m FROM aliases GROUP BY alias) t ON a.rowid = t.m ORDER BY a.alias",
        [])
    if is_error(r) { return [] }
    out = []
    for row in unwrap(r) {
        out = append(out, make_record([["alias", row[0]], ["canonical", row[1]], ["bound_at", row[2]]]))
    }
    return out
}

// ---------- Discord user mapping ----------

fn db_bind_discord(discord_id: Text, stoa_name: Text, ts: Text) -> Any {
    _ensure_db()
    db = get_db_file()
    return perform db.execute(db,
        "INSERT INTO discord_users (discord_id, stoa_name, bound_at) VALUES (?, ?, ?)",
        [discord_id, stoa_name, ts])
}

fn db_lookup_discord(discord_id: Text) -> Text {
    _ensure_db()
    db = get_db_file()
    r = perform db.query(db,
        "SELECT stoa_name FROM discord_users WHERE discord_id = ? ORDER BY rowid DESC LIMIT 1",
        [discord_id])
    if is_error(r) { return "" }
    rows = unwrap(r)
    if length(rows) == 0 { return "" }
    return to_text(rows[0][0])
}

// ---------- Discord interactions (Discord → Stoa) ----------
//
// 디스코드 슬래시 커맨드가 도착하는 곳. Ed25519 서명 검증은 Python flask
// before_request hook이 자동 처리 (DISCORD_PUBLIC_KEY env 필요).
//
// 등록한 슬래시 커맨드: /letter to:<name> message:<text>
//   from = "hyun06000" (현 단계 단일 사용자 가정 — 이후 discord_id → name
//   매핑으로 확장 가능)

fn _discord_pong() -> [Any] {
    return [200, "application/json", "{\"type\":1}"]
}

fn _discord_reply(text: Text) -> [Any] {
    body = make_record([["type", 4], ["data", make_record([["content", text]])]])
    return [200, "application/json", msg_to_json(body)]
}

fn _slash_options_get(options: Any, name: Text) -> Text {
    if options == None { return "" }
    for opt in options {
        if to_text(get(opt, "name")) == name {
            v = get(opt, "value")
            if v != None { return to_text(v) }
        }
    }
    return ""
}

fn _discord_user_id(body: Any) -> Text {
    // Guild interaction에서는 member.user.id, DM에서는 user.id에 있음.
    member = get(body, "member")
    if member != None {
        u = get(member, "user")
        if u != None {
            uid = get(u, "id")
            if uid != None { return to_text(uid) }
        }
    }
    u2 = get(body, "user")
    if u2 != None {
        uid2 = get(u2, "id")
        if uid2 != None { return to_text(uid2) }
    }
    return ""
}

fn _resolve_sender(body: Any) -> Any {
    discord_id = _discord_user_id(body)
    stoa_name = ""
    if discord_id != "" {
        stoa_name = db_lookup_discord(discord_id)
    }
    if stoa_name == "" { return None }
    rcp = db_lookup(stoa_name)
    if rcp == None { return None }
    return make_record([["name", get(rcp, "name")], ["address", get(rcp, "address")]])
}

fn handle_discord(req: Any) -> [Any] {
    parsed = parse_json(req.body)
    if is_error(parsed) { return [400, "text/plain", "bad JSON"] }
    body = unwrap(parsed)

    itype = get(body, "type")
    if itype == 1 { return _discord_pong() }
    if itype != 2 { return _discord_reply("(unsupported interaction type)") }

    data = get(body, "data")
    cmd = to_text(get(data, "name"))
    options = get(data, "options")
    discord_id = _discord_user_id(body)

    if cmd == "enter" {
        name = _slash_options_get(options, "name")
        webhook = _slash_options_get(options, "webhook")
        if name == "" {
            return _discord_reply("❌ name: 이 필요해.")
        }
        if discord_id == "" {
            return _discord_reply("❌ Discord 사용자 정보를 못 읽었어.")
        }
        address = webhook
        if address == "" {
            address = join(["https://ail-stoa.up.railway.app/inbox/", name], "")
        }
        ts = now_iso()
        db_register(name, address, None, ts)
        db_bind_discord(discord_id, name, ts)
        return _discord_reply(join(["✅ '", name, "'으로 등록됐어. 이제 /letter 보내면 from이 너야.\n주소: ", address], ""))
    }

    if cmd == "alias" {
        alias_v = _slash_options_get(options, "alias")
        for_v = _slash_options_get(options, "for")
        if alias_v == "" or for_v == "" {
            return _discord_reply("❌ alias: 와 for: 둘 다 필요해.")
        }
        if db_lookup(for_v) == None {
            return _discord_reply(join(["❌ '", for_v, "'은 registry에 미등록 — 먼저 그 사람이 /enter 해야 해."], ""))
        }
        ts = now_iso()
        db_add_alias(alias_v, for_v, ts)
        return _discord_reply(join(["🔗 '", alias_v, "' → '", for_v, "' 등록 완료. 이제 /letter to:", alias_v, " 로 보내도 돼."], ""))
    }

    if cmd == "status" {
        _ensure_db()
        db = get_db_file()
        // 전체 편지 수
        r1 = perform db.query(db, "SELECT COUNT(*) FROM letters", [])
        total_letters = 0
        if not is_error(r1) {
            rows = unwrap(r1)
            if length(rows) > 0 { total_letters = to_number(rows[0][0]) }
        }
        // 등록된 사람 수 (latest per name)
        r2 = perform db.query(db, "SELECT COUNT(DISTINCT name) FROM registry", [])
        total_agents = 0
        if not is_error(r2) {
            rows2 = unwrap(r2)
            if length(rows2) > 0 { total_agents = to_number(rows2[0][0]) }
        }
        // 내 정체 + 인박스
        my_line = "(미등록)"
        if discord_id != "" {
            my_name = db_lookup_discord(discord_id)
            if my_name != "" {
                my_inbox = db_inbox_for(my_name, 100, "")
                my_line = join([my_name, " — 인박스 ", to_text(length(my_inbox)), "통"], "")
            }
        }
        text = join([
            "🏛 Stoa 상태\n",
            "  • 전체 편지: ", to_text(total_letters), "\n",
            "  • 등록된 이름: ", to_text(total_agents), "\n",
            "  • 너: ", my_line, "\n",
            "  • 버전: 0.0.11"
        ], "")
        return _discord_reply(text)
    }

    if cmd == "whoami" {
        if discord_id == "" {
            return _discord_reply("❌ Discord 사용자 정보를 못 읽었어.")
        }
        bound = db_lookup_discord(discord_id)
        if bound == "" {
            return _discord_reply("👤 아직 등록 안 됨. /enter name:<원하는 이름> 으로 등록해줘.")
        }
        rcp = db_lookup(bound)
        addr = "(registry에서 못 찾음)"
        if rcp != None { addr = to_text(get(rcp, "address")) }
        return _discord_reply(join(["👤 너는 Stoa에서 '", bound, "'\n주소: ", addr], ""))
    }

    if cmd == "letter" {
        to_input = _slash_options_get(options, "to")
        content = _slash_options_get(options, "message")
        if to_input == "" or content == "" {
            return _discord_reply("❌ to: 와 message: 둘 다 필요해.")
        }
        // alias → canonical 해소 후 lookup
        to_name = resolve_name(to_input)
        rcp = db_lookup(to_name)
        if rcp == None {
            return _discord_reply(join(["❌ '", to_input, "'은 registry에 없어."], ""))
        }
        // sender — discord_id 매핑이 있으면 그걸로, 없으면 미등록 안내
        from_obj = _resolve_sender(body)
        if from_obj == None {
            return _discord_reply("❌ 너 아직 Stoa에 미등록. 먼저 /enter name:<원하는 이름> 해줘.")
        }
        recipients = [make_record([["name", get(rcp, "name")], ["address", get(rcp, "address")]])]
        msg_id = make_id()
        created_at = now_iso()
        _ensure_db()
        db_insert_letter(msg_id,
            to_text(get(from_obj, "name")),
            to_text(get(from_obj, "address")),
            content, created_at, None, None)
        for r in recipients {
            db_insert_recipient(msg_id, to_text(get(r, "name")), to_text(get(r, "address")))
        }
        envelope = make_record([
            ["id", msg_id],
            ["from", from_obj],
            ["to", recipients],
            ["content", content],
            ["created_at", created_at]
        ])
        // mirror만 — push는 timeout 위험 때문에 생략 (수신자는 폴러로 가져감)
        notify_discord(envelope)
        // 응답에 내용도 같이 보여줘서 채널에 흔적이 남도록
        text = join([
            "✉️ **", to_text(get(from_obj, "name")), "** → **", to_name, "**\n",
            content, "\n",
            "_id: ", msg_id, "_"
        ], "")
        return _discord_reply(text)
    }

    return _discord_reply(join(["(unknown command: ", cmd, ")"], ""))
}

fn handle_debug_discord(req: Any) -> [Any] {
    url = get_discord_webhook()
    webhook_info = make_record([
        ["env_set", url != ""],
        ["env_length", length(url)],
        ["env_prefix_ok", starts_with(url, "https://discord.com/api/webhooks/")]
    ])

    // Public Key 진단 — Discord Application Public Key는 정확히 64자 hex여야 함
    pk_r = perform env.read("DISCORD_PUBLIC_KEY")
    pk_set = not is_error(pk_r)
    pk_len = 0
    pk_preview = ""
    pk_is_hex64 = false
    if pk_set {
        pk = trim(unwrap(pk_r))
        pk_len = length(pk)
        if pk_len >= 6 {
            pk_preview = slice(pk, 0, 6)
        }
        pk_is_hex64 = pk_len == 64
    }
    pk_info = make_record([
        ["env_set", pk_set],
        ["length", pk_len],
        ["expected_length", 64],
        ["length_ok", pk_is_hex64],
        ["preview", pk_preview]
    ])

    test_result = "skipped (no webhook env)"
    if url != "" {
        payload = make_record([["content", "🛠 stoa debug ping"]])
        resp = perform http.post_json(url, payload, [], timeout: 5)
        if is_error(resp) {
            test_result = join(["error: ", to_text(resp)], "")
        } else {
            test_result = "ok"
        }
    }

    body = make_record([
        ["webhook", webhook_info],
        ["public_key", pk_info],
        ["webhook_test", test_result]
    ])
    return json_ok(200, msg_to_json(body))
}

// ---------- registry ----------
//
// 누가 어디서 듣고 있나. append-only — 같은 name의 최신 행이 현재 주소.
// 보안 없음 (현 단계). 누구든 자기 이름과 주소를 등록할 수 있고, 같은 이름으로
// 다시 등록하면 새 row가 쌓이고 latest가 곧 현재.

// db_register: public_key는 hex Text 또는 None (grandfather row).
fn db_register(name: Text, address: Text, public_key: Any, ts: Text) -> Any {
    _ensure_db()
    db = get_db_file()
    return perform db.execute(db,
        "INSERT INTO registry (name, address, public_key, registered_at) VALUES (?, ?, ?, ?)",
        [name, address, public_key, ts])
}

fn db_lookup(name: Text) -> Any {
    _ensure_db()
    db = get_db_file()
    r = perform db.query(db,
        "SELECT name, address, public_key, registered_at FROM registry WHERE name = ? ORDER BY rowid DESC LIMIT 1",
        [name])
    if is_error(r) { return None }
    rows = unwrap(r)
    if length(rows) == 0 { return None }
    row = rows[0]
    return make_record([["name", row[0]], ["address", row[1]], ["public_key", row[2]], ["registered_at", row[3]]])
}

fn db_list_registry() -> [Any] {
    _ensure_db()
    db = get_db_file()
    r = perform db.query(db,
        "SELECT r.name, r.address, r.public_key, r.registered_at FROM registry r INNER JOIN (SELECT name, MAX(rowid) AS m FROM registry GROUP BY name) t ON r.rowid = t.m ORDER BY r.name",
        [])
    if is_error(r) { return [] }
    out = []
    for row in unwrap(r) {
        out = append(out, make_record([["name", row[0]], ["address", row[1]], ["public_key", row[2]], ["registered_at", row[3]]]))
    }
    return out
}

// ---------- platform_keys (RFC-002 §6.4) ----------
//
// platform attestation 공개키 보관·조회. private key는 운영자가 env vault 보유,
// 본 테이블은 검증 측 lookup(`§6.6 attestation.platform_key_id` → pubkey)에만.
// append-only — INSERT만, latest wins via rowid.

fn db_register_platform_key(id: Text, public_key: Text, ts: Text) -> Any {
    _ensure_db()
    db = get_db_file()
    return perform db.execute(db,
        "INSERT INTO platform_keys (id, public_key, registered_at) VALUES (?, ?, ?)",
        [id, public_key, ts])
}

fn db_get_platform_pubkey(id: Text) -> Any {
    _ensure_db()
    db = get_db_file()
    r = perform db.query(db,
        "SELECT public_key FROM platform_keys WHERE id = ? ORDER BY rowid DESC LIMIT 1",
        [id])
    if is_error(r) { return None }
    rows = unwrap(r)
    if length(rows) == 0 { return None }
    return to_text(rows[0][0])
}

fn db_list_platform_keys() -> [Any] {
    _ensure_db()
    db = get_db_file()
    r = perform db.query(db,
        "SELECT p.id, p.public_key, p.registered_at FROM platform_keys p INNER JOIN (SELECT id, MAX(rowid) AS m FROM platform_keys GROUP BY id) t ON p.rowid = t.m ORDER BY p.id",
        [])
    if is_error(r) { return [] }
    out = []
    for row in unwrap(r) {
        out = append(out, make_record([["id", row[0]], ["public_key", row[1]], ["registered_at", row[2]]]))
    }
    return out
}

// _is_lower_hex64: ed25519 공개키 형식 — 64자 lower-case hex. _nonce_format_ok 패턴.
fn _is_lower_hex64(s: Text) -> Boolean {
    if length(s) != 64 { return false }
    for i in range(0, 64) {
        c = slice(s, i, i + 1)
        is_digit = c >= "0" and c <= "9"
        is_hex_lc = c >= "a" and c <= "f"
        if not (is_digit or is_hex_lc) { return false }
    }
    return true
}

// ---------- active push ----------
//
// 수신자 address가 Discord webhook URL이면 envelope을 Discord shape으로
// reformat 후 POST. 그 외는 envelope을 그대로 POST (HEAAL — 받는 곳이 누구든
// 보내는 쪽은 envelope 의미 보존).

fn _is_discord_url(addr: Text) -> Boolean {
    return starts_with(addr, "https://discord.com/api/webhooks/")
}

fn _envelope_to_discord(envelope: Any) -> Any {
    from_name = to_text(get(get(envelope, "from"), "name"))
    to_label = _to_label(get(envelope, "to"))
    content = to_text(get(envelope, "content"))
    text = join(["📨 **", from_name, "** → ", to_label, "\n", content], "")
    return make_record([["content", text]])
}

// _push_one: 수신자 listener로 envelope POST. issue#2 hotfix —
// `perform http.post_json`이 timeout/connection-refused 등에서 effect 예외로
// raise하면 caller 핸들러가 500 으로 죽음 (is_error는 Result error만 catch).
// attempt+try는 perform 예외를 fallback으로 흡수해 Result-error로 변환 가능
// (reference card: "attempt blocks CAN contain perform tries, enabling fallback
// patterns"). 그 결과를 push_to_recipients의 is_error 분기가 정상 catch.
fn _push_one(addr: Text, envelope: Any) -> Any {
    payload = envelope
    if _is_discord_url(addr) { payload = _envelope_to_discord(envelope) }
    return attempt {
        try perform http.post_json(addr, payload, [], timeout: 3)
        try error("push failed: listener unreachable or timeout")
    }
}

// _push_one_fast: autonomous tick(`on_tick`) 안 push. timeout 짧게(1s) 잡아 hook
// budget 초과 차단 — TICK_SEC=1 환경에서 sink port 같은 SYN-hang case 한 번에
// 흡수 가능. 통상 listener 응답은 ms 단위라 1s로도 충분. 실패 시 다음 tick에
// retry, 누적 실패는 escalate 트리거 (RFC §3.4).
fn _push_one_fast(addr: Text, envelope: Any) -> Any {
    payload = envelope
    if _is_discord_url(addr) { payload = _envelope_to_discord(envelope) }
    return attempt {
        try perform http.post_json(addr, payload, [], timeout: 1)
        try error("push failed: listener unreachable or timeout (fast)")
    }
}

// _is_self_host: 수신자 address가 자기 host(현재 요청 origin)와 같은가.
// issue#3 — 컨테이너 내부 → public hostname HTTPS loopback이 TCP/TLS 단계에서
// hang. 자기 host는 push 자체가 불필요(letter는 같은 DB에 이미 INSERT). skip이
// 가장 가벼운 fix.
//
// 4차 다운 hotfix (c) fallback A (2026-05-12) — self_origin이 빈 문자열일 때
// 옛 동작은 *항상 false* → `STOA_SELF_ORIGIN` 미설정 + autonomous tick path에서
// `_pump_subscriber`가 자기 self-row(Stoa-Stoa)·자기 listener 주소에까지 push
// 시도 → Railway public hostname loopback hang → 매 tick urllib 객체 leak →
// OOM kill 4일 후 (Stoa#11 RCA).
//
// fallback A: env 빈 문자열이면 registry `Stoa-Stoa` self-row의 address를 회수해
// 그 prefix로 self-host 판정. self-row가 _stoa_origin/inbox/Stoa-Stoa 형식이라
// host prefix 일치 — 자기 host로 가는 모든 push 차단. env 없이도 leak trigger
// 제거. (B 정교판: 첫 request Host header latch는 사이클 9.)
//
// db_lookup 실패 (registry 누락·DB error)이면 옛 동작(false)으로 떨어져 가용성
// 보존 — fallback의 fallback. self-row는 on_birth/_init_db 자리에서 항상 INSERT
// 되므로 정상 path에서는 None 안 됨.
//
// 사이클 9 fallback B land — `_stoa_origin(req)`가 첫 request에서
// `server.self_origin` state에 origin을 latch, autonomous tick path는 state
// read로 회수. 본 함수의 self_origin 인자는 호출자가 (a) request 핸들러에서
// `_stoa_origin(req)` 결과, (b) autonomous tick에서 `_get_self_origin()` 결과로
// 전달 — 양쪽 모두 state-aware. 빈 문자열 cold-start 분기는 cold-start 첫
// request·tick 사이의 좁은 창에만 들어오고 fallback A가 회수.
fn _is_self_host(addr: Text, self_origin: Text) -> Boolean {
    if self_origin != "" {
        return starts_with(addr, self_origin)
    }
    // fallback A — registry self-row address로 비교.
    row = db_lookup("Stoa-Stoa")
    if row == None { return false }
    self_addr = to_text(get(row, "address"))
    if self_addr == "" { return false }
    // self_addr는 보통 https://host/inbox/Stoa-Stoa 형식 — host prefix만 떼서
    // 비교하려면 path 구분점이 필요. 단순화: addr가 self_addr와 동일하거나
    // self_addr의 scheme://host prefix를 공유하면 self. parse_url builtin 없이
    // "/inbox/" 위치까지 자르는 휴리스틱.
    cut_at = index_of(self_addr, "/inbox/")
    if cut_at < 0 {
        // self-row가 /inbox/ 자리 없으면 exact match만.
        return addr == self_addr
    }
    self_origin_inferred = slice(self_addr, 0, cut_at)
    if self_origin_inferred == "" { return false }
    return starts_with(addr, self_origin_inferred)
}

// push_to_recipients: issue#3 hotfix — self-host skip + skipped 카운터.
// 호출자가 self_origin(_stoa_origin(req)) 전달. self_origin과 prefix-매칭되는
// recipient는 push 시도 0, skipped++. 외부 receivers는 issue#2 fix(_push_one
// attempt+try) 그대로.
fn push_to_recipients(recipients: [Any], envelope: Any, self_origin: Text) -> Any {
    delivered = 0
    failed = 0
    skipped = 0
    for r in recipients {
        addr = to_text(get(r, "address"))
        if _is_self_host(addr, self_origin) {
            skipped = skipped + 1
        } else {
            resp = _push_one(addr, envelope)
            if is_error(resp) {
                failed = failed + 1
            } else {
                delivered = delivered + 1
            }
        }
    }
    return make_record([["delivered", delivered], ["failed", failed], ["skipped", skipped]])
}

// ---------- response helpers ----------

fn json_ok(status: Number, body: Text) -> [Any] {
    return [status, "application/json", body]
}

fn err_json(status: Number, message: Text) -> [Any] {
    body = join(["{\"error\":\"", message, "\"}"], "")
    return [status, "application/json", body]
}

fn msg_to_json(msg: Any) -> Text {
    enc = encode_json(msg)
    if is_error(enc) { return "{}" }
    return unwrap(enc)
}

// ---------- handlers ----------

fn handle_health(req: Any) -> [Any] {
    // bridge v0 §4.1 wake bundle inflate 가시 + RFC-004 §3.4 autonomous tick 가시.
    // last_wake_inflated_at == "" → inflate 0 (Phase B/C wire-up 전).
    // last_tick_at == "" → on_tick 미발화 (autonomous loop 미가동, AC-B5 surface).
    inflated = _get_self_wake_inflated_at()
    last_tick = ""
    tr = perform state.read("health.last_tick_at")
    if not is_error(tr) { last_tick = to_text(unwrap(tr)) }
    // 사이클 9 fallback B 가시 — self_origin latch 상태 노출. 운영자가 deploy 직후
    // 첫 request에서 latch 값이 기대 host와 일치하는지 확인 가능. cold-start
    // 직후 request 0건 상태에서는 빈 문자열 (fallback A로 self-host 회수 중).
    self_origin = ""
    so_r = perform state.read("server.self_origin")
    if not is_error(so_r) { self_origin = to_text(unwrap(so_r)) }
    body = make_record([
        ["status", "ok"],
        ["version", "0.0.17"],
        ["last_wake_inflated_at", inflated],
        ["last_tick_at", last_tick],
        ["self_origin", self_origin]
    ])
    return json_ok(200, msg_to_json(body))
}

fn handle_post_message(req: Any) -> [Any] {
    parsed = parse_json(req.body)
    if is_error(parsed) { return err_json(400, "invalid JSON body") }
    body = unwrap(parsed)

    v = validate_envelope(body)
    if is_error(v) { return err_json(400, unwrap_error(v)) }
    norm = unwrap(v)

    from_name = to_text(get(norm, "from_name"))
    from_address = to_text(get(norm, "from_address"))
    content = to_text(get(norm, "content"))

    // §6.4 검증 시점 — Stoa 진입 시 단일 게이트.
    // signature/nonce/created_at는 client 측 envelope. 검증 흐름이 활성이면
    // canonical 재구성에 client created_at 사용해야 함(서명·검증 byte 일치).
    sig_v = get(body, "signature")
    nonce_v = get(body, "nonce")
    ca_v = get(body, "created_at")
    has_sig_claim = sig_v != None and to_text(sig_v) != ""

    // Q1 §6.5 hotfix — Web UI POST 차단. from.name이 discord_users에 등재된 사람이고
    // envelope에 attestation(signature) 부재면 401. Discord 사람 letter는 §6 full
    // (Step 5/6) attestation land까지 일시 정지 default — 같은 분기로 자연 reject.
    // 401 메시지는 enumeration 방어 위해 통일 ('unauthorized envelope').
    if _is_human_bound(from_name) and not has_sig_claim {
        return err_json(401, "unauthorized envelope")
    }

    // issue#4 Phase A — 송신자 registry 강제 (impersonation 방어).
    // 수신자 to.name은 이미 registry 등재 필수인데 from.name은 무방비였다.
    // Phase 2/3 서명 강제 land 전까지 평등 게이트로 차단. 자동 self-register 안 함
    // — 그게 곧 impersonation 허용. 미등록 발신자는 POST /api/v1/enter로 명시 등록 후 재시도.
    sender = db_lookup(from_name)
    if sender == None {
        return err_json(400, join(["sender '", from_name, "' not in registry. Register via POST /api/v1/enter first."], ""))
    }
    sender_pk = None
    spk = get(sender, "public_key")
    if spk != None and to_text(spk) != "" { sender_pk = to_text(spk) }
    phase = _get_signing_phase()

    // verify_required 결정 (RFC §8 표):
    //   Phase 0: 결코 안 함.
    //   Phase 1: 서명 *주장*하면 강제(없으면 통과).
    //   Phase 2: sender_pk != None 이면 강제. None이면 무서명 통과(grandfather).
    //   Phase 3: 항상 강제. sender_pk == None 이면 검증 자체 불가 → 403.
    verify_required = false
    if phase == 1 and has_sig_claim { verify_required = true }
    if phase == 2 and sender_pk != None { verify_required = true }
    if phase == 3 { verify_required = true }

    if phase == 3 and sender_pk == None {
        return err_json(403, "key required: sender has no registered public_key (Phase 3)")
    }

    if verify_required {
        if not has_sig_claim or nonce_v == None or ca_v == None {
            return err_json(400, "signature, nonce, created_at required at this phase")
        }
        if sender_pk == None {
            // Phase 1 서명 *주장* 했으나 발신자 키 없음 → 검증 불가.
            return err_json(403, "signature claimed but sender has no registered public_key")
        }
        signature = to_text(sig_v)
        nonce = to_text(nonce_v)
        client_created_at = to_text(ca_v)
        if signature == "" or nonce == "" or client_created_at == "" {
            return err_json(400, "signature/nonce/created_at must be non-empty")
        }
        // canonical: norm 의 raw recipients (resolve 전) + client created_at + nonce.
        // 발신자 측 서명 대상이 정확히 이 형식이어야 함 (alias 해소·address rewrite 전).
        raw_recipients = []
        for r in get(norm, "recipients") {
            raw_recipients = append(raw_recipients, make_record([
                ["name", get(r, "name")],
                ["address", get(r, "address")]
            ]))
        }
        if not _nonce_format_ok(nonce) {
            return err_json(400, "nonce format invalid (lower-case hex, 32+ chars)")
        }
        if not _within_window(client_created_at, _get_window_seconds()) {
            return err_json(403, "created_at out of window")
        }
        canon = canonical_letter(from_name, from_address, raw_recipients, content, client_created_at, nonce)
        if not crypto_verify_ed25519(sender_pk, signature, canon) {
            return err_json(403, "signature verification failed")
        }
        rec = db_record_seen_nonce(from_name, nonce, now_iso())
        if is_error(rec) {
            return err_json(403, "nonce already used")
        }
    }

    _ensure_db()
    msg_id = make_id()
    // 저장 created_at: 검증 통과한 흐름이면 client 값(서명 round-trip 가능),
    // 그 외에는 server now (legacy / Phase 0).
    created_at = now_iso()
    if verify_required { created_at = to_text(ca_v) }

    // recipients: alias → canonical 해소. address도 registry 기준으로 갱신
    // (사용자가 alias 적었을 때 latest canonical address로 보내도록).
    // 주의: alias 해소는 push 흐름용이며, 서명 canonical은 위에서 raw로 처리.
    resolved_recipients = []
    for r in get(norm, "recipients") {
        rname = to_text(get(r, "name"))
        canon = resolve_name(rname)
        addr = to_text(get(r, "address"))
        canon_entry = db_lookup(canon)
        if canon_entry != None {
            addr = to_text(get(canon_entry, "address"))
        }
        resolved_recipients = append(resolved_recipients,
            make_record([["name", canon], ["address", addr]]))
    }

    // §6.5 envelope 보존 — signature/nonce/created_at 그대로 forward + DB 보관.
    // verify_required 흐름이 아니어도 client가 signature 보냈으면 echo+저장 (Phase 0/1
    // optional 흐름 호환). DB 컬럼 추가는 PRINCIPLES §3 양립 (row 변경 아님).
    sig_echo = None
    nonce_echo = None
    if has_sig_claim { sig_echo = to_text(sig_v) }
    if nonce_v != None and to_text(nonce_v) != "" { nonce_echo = to_text(nonce_v) }

    // INSERT only — code path has no UPDATE / no DELETE.
    db_insert_letter(msg_id, from_name, from_address, content, created_at, sig_echo, nonce_echo)
    for r in resolved_recipients {
        db_insert_recipient(msg_id, to_text(get(r, "name")), to_text(get(r, "address")))
    }

    envelope = make_record([
        ["id", msg_id],
        ["from", make_record([
            ["name", from_name],
            ["address", from_address]
        ])],
        ["to", resolved_recipients],
        ["content", content],
        ["created_at", created_at],
        ["nonce", nonce_echo],
        ["signature", sig_echo]
    ])

    // notify_discord 먼저 — push가 timeout으로 raise하면 핸들러가 500되어
    // mirror가 영영 안 탐. mirror는 보존되어야 할 신호이므로 우선.
    notify_discord(envelope)
    self_origin = _stoa_origin(req)
    push = push_to_recipients(resolved_recipients, envelope, self_origin)

    response = make_record([["envelope", envelope], ["push", push]])
    return json_ok(201, msg_to_json(response))
}

fn handle_list_inbox(req: Any) -> [Any] {
    name_v = get(req.args, "to")
    limit_v = get(req.args, "limit")
    since_v = get(req.args, "since_id")
    limit = 50
    if limit_v != None { limit = to_number(limit_v) }
    since_id = ""
    if since_v != None { since_id = to_text(since_v) }
    if name_v == None or to_text(name_v) == "" {
        // ?to= 미지정 → 모두의 편지 (시간 역순)
        msgs = db_all_letters(limit, since_id)
        body = make_record([
            ["recipient", "*"],
            ["messages", msgs],
            ["count", length(msgs)]
        ])
        return json_ok(200, msg_to_json(body))
    }
    canonical = resolve_name(to_text(name_v))
    msgs = db_inbox_for(canonical, limit, since_id)
    body = make_record([
        ["recipient", canonical],
        ["messages", msgs],
        ["count", length(msgs)]
    ])
    return json_ok(200, msg_to_json(body))
}

fn handle_get_message(req: Any, msg_id: Text) -> [Any] {
    env_obj = db_get_letter(msg_id)
    if env_obj == None { return err_json(404, "letter not found") }
    return json_ok(200, msg_to_json(env_obj))
}

// ---------- RFC-004 §4 inbox handlers (Phase A) ----------
//
// GET  /api/v1/inbox?to=<name>           — 미전달 letter 반환 (cursor advance 안 함).
// POST /api/v1/inbox/ack {to, up_to_msg_id} — server cursor advance.
//
// 옛 GET /api/v1/messages는 무변경 보존 (back-compat, AC-A7). 새 흐름과 cursor
// 도메인 분리.

fn handle_inbox_get(req: Any) -> [Any] {
    name_v = get(req.args, "to")
    if name_v == None or to_text(name_v) == "" {
        return err_json(400, "missing 'to' query param")
    }
    limit_v = get(req.args, "limit")
    limit = 50
    if limit_v != None { limit = to_number(limit_v) }
    canonical = resolve_name(to_text(name_v))
    cursor = _get_cursor(canonical)
    msgs = db_inbox_for(canonical, limit, cursor)
    // continuation_token: 본 응답에 담긴 letter들 중 가장 최신(첫 위치, DESC 정렬)의
    // id. 클라이언트는 ack {up_to_msg_id: <continuation_token>}로 cursor를 advance.
    cont = ""
    if length(msgs) > 0 {
        cont = to_text(get(msgs[0], "id"))
    }
    body = make_record([
        ["recipient", canonical],
        ["messages", msgs],
        ["count", length(msgs)],
        ["continuation_token", cont]
    ])
    return json_ok(200, msg_to_json(body))
}

fn handle_inbox_ack(req: Any) -> [Any] {
    parsed = parse_json(req.body)
    if is_error(parsed) { return err_json(400, "invalid JSON body") }
    body = unwrap(parsed)
    n = _check_str(body, "to")
    if is_error(n) { return err_json(400, unwrap_error(n)) }
    m = _check_str(body, "up_to_msg_id")
    if is_error(m) { return err_json(400, unwrap_error(m)) }
    name = resolve_name(to_text(unwrap(n)))
    mid = to_text(unwrap(m))
    ts = now_iso()
    new_cur = _advance_cursor(name, mid, ts)
    body_out = make_record([
        ["recipient", name],
        ["cursor", new_cur]
    ])
    return json_ok(200, msg_to_json(body_out))
}

// ---------- registry handlers ----------

// _register_gate: §5.1 / §5.2 게이트 공통 로직. handle_register / handle_enter 둘이 공유.
// 반환 record:
//   {"ok": true,  "public_key": <pk|null>, "registered_at": <ts>}     — INSERT 완료
//   {"ok": false, "code": <http>, "msg": <text>}                      — 거절
//
// 참고:
// - Phase 0 (default): 어떤 검증도 안 함, 기존 동작 유지.
// - Phase 1: 이름·주소만 있으면 통과 (옵션 서명 검증은 Step 2b/3 범위).
// - Phase 2/3: §5.2 키 보유 이름 재등록 시 signature/nonce/created_at 필수 + crypto_verify + nonce dedup.
//   created_at window 검증은 Step 4(§7.1)에서 추가.
fn _register_gate(name: Text, address: Text, body: Any) -> Any {
    pk_v = get(body, "public_key")
    pk_text = None
    if pk_v != None and to_text(pk_v) != "" {
        pk_text = to_text(pk_v)
    }

    phase = _get_signing_phase()
    prev = db_lookup(name)
    prev_pk = None
    if prev != None {
        pp = get(prev, "public_key")
        if pp != None and to_text(pp) != "" { prev_pk = to_text(pp) }
    }

    // Phase 2/3 + 기등록 키 보유 → §5.2 게이트.
    if phase >= 2 and prev_pk != None {
        sig_v = get(body, "signature")
        nonce_v = get(body, "nonce")
        ca_v = get(body, "created_at")
        if sig_v == None or nonce_v == None or ca_v == None or pk_text == None {
            return make_record([["ok", false], ["code", 400], ["msg", "key required for re-registration: public_key, signature, nonce, created_at"]])
        }
        signature = to_text(sig_v)
        nonce = to_text(nonce_v)
        created_at = to_text(ca_v)
        if signature == "" or nonce == "" or created_at == "" {
            return make_record([["ok", false], ["code", 400], ["msg", "signature/nonce/created_at must be non-empty"]])
        }
        if not _nonce_format_ok(nonce) {
            return make_record([["ok", false], ["code", 400], ["msg", "nonce format invalid (lower-case hex, 32+ chars)"]])
        }
        if not _within_window(created_at, _get_window_seconds()) {
            return make_record([["ok", false], ["code", 403], ["msg", "created_at out of window"]])
        }
        canon = canonical_register(name, address, pk_text, created_at, nonce)
        if not crypto_verify_ed25519(prev_pk, signature, canon) {
            return make_record([["ok", false], ["code", 403], ["msg", "signature verification failed"]])
        }
        rec = db_record_seen_nonce(name, nonce, now_iso())
        if is_error(rec) {
            return make_record([["ok", false], ["code", 403], ["msg", "nonce already used"]])
        }
    }

    // INSERT (Phase 0/1 또는 §5.1 새 이름 또는 §5.2 grandfather one-shot 모두 도달).
    ts = now_iso()
    db_register(name, address, pk_text, ts)
    return make_record([["ok", true], ["public_key", pk_text], ["registered_at", ts]])
}

fn handle_register(req: Any) -> [Any] {
    parsed = parse_json(req.body)
    if is_error(parsed) { return err_json(400, "invalid JSON body") }
    body = unwrap(parsed)

    n = _check_str(body, "name")
    if is_error(n) { return err_json(400, unwrap_error(n)) }
    a = _check_str(body, "address")
    if is_error(a) { return err_json(400, unwrap_error(a)) }

    name = to_text(unwrap(n))
    address = to_text(unwrap(a))

    g = _register_gate(name, address, body)
    if get(g, "ok") == false {
        return err_json(get(g, "code"), to_text(get(g, "msg")))
    }

    body_out = make_record([
        ["name", name],
        ["address", address],
        ["public_key", get(g, "public_key")],
        ["registered_at", get(g, "registered_at")]
    ])
    return json_ok(201, msg_to_json(body_out))
}

fn handle_list_registry(req: Any) -> [Any] {
    items = db_list_registry()
    body = make_record([["count", length(items)], ["agents", items]])
    return json_ok(200, msg_to_json(body))
}

fn handle_lookup(req: Any, name: Text) -> [Any] {
    canonical = resolve_name(name)
    item = db_lookup(canonical)
    if item == None { return err_json(404, "name not registered") }
    return json_ok(200, msg_to_json(item))
}

// ---------- platform_keys handlers (RFC-002 §6.4) ----------
//
// POST /api/v1/platform-keys      operator-only 등록 (env token gate)
// GET  /api/v1/platform-keys      목록 (latest per id)
// GET  /api/v1/platform-keys/:id  단건 조회
//
// 토큰 게이트: STOA_PLATFORM_REGISTER_TOKEN env 미설정 → endpoint 503 (default 비활성).
// 설정 시 X-Platform-Token 헤더와 일치해야 통과. v2 후보(§6.4.3): rotation 자동, HSM,
// multi-key 검증 윈도. 본 v1은 운영자가 수동 INSERT, append-only로 키 이력 보존.

fn handle_register_platform_key(req: Any) -> [Any] {
    tok_r = perform env.read("STOA_PLATFORM_REGISTER_TOKEN")
    if is_error(tok_r) {
        return err_json(503, "platform key registration disabled (STOA_PLATFORM_REGISTER_TOKEN unset)")
    }
    expected = trim(unwrap(tok_r))
    if expected == "" {
        return err_json(503, "platform key registration disabled (STOA_PLATFORM_REGISTER_TOKEN empty)")
    }
    h = req.headers
    got = get(h, "X-Platform-Token")
    if got == None { got = get(h, "x-platform-token") }
    if got == None or to_text(got) != expected {
        return err_json(401, "invalid platform token")
    }

    parsed = parse_json(req.body)
    if is_error(parsed) { return err_json(400, "invalid JSON body") }
    body = unwrap(parsed)
    if not _is_record(body) { return err_json(400, "body must be a JSON object") }

    i = _check_str(body, "id")
    if is_error(i) { return err_json(400, unwrap_error(i)) }
    p = _check_str(body, "public_key")
    if is_error(p) { return err_json(400, unwrap_error(p)) }
    id_t = to_text(unwrap(i))
    pk_t = to_text(unwrap(p))

    if not _is_lower_hex64(pk_t) {
        return err_json(400, "public_key must be 64-char lower-case hex (ed25519)")
    }

    ts = now_iso()
    db_register_platform_key(id_t, pk_t, ts)
    out = make_record([["id", id_t], ["public_key", pk_t], ["registered_at", ts]])
    return json_ok(201, msg_to_json(out))
}

fn handle_list_platform_keys(req: Any) -> [Any] {
    items = db_list_platform_keys()
    body = make_record([["count", length(items)], ["platform_keys", items]])
    return json_ok(200, msg_to_json(body))
}

fn handle_lookup_platform_key(req: Any, id: Text) -> [Any] {
    items = db_list_platform_keys()
    for item in items {
        if to_text(get(item, "id")) == id {
            return json_ok(200, msg_to_json(item))
        }
    }
    return err_json(404, "platform key id not registered")
}

// ---------- Q1 Phase A: password / login / sessions ----------
//
// 박상현 신호 (2026-05-04 priority:high): "WebUI에 로그인 시스템 없음, 아무나 아무
// 이름으로 메일 보내기 가능". 후속 보강 "간단한 로그인이라도".
//
// 설계:
//   - registry.password_hash: env-keyed ed25519 MAC. salt(32hex)$mac(128hex). NULL = 미설정 = login 불가.
//     AIL stdlib에 sha256/bcrypt 부재 → ed25519 sign(env_key, salt|name|password)으로 MAC 대체.
//   - sessions(token, name, created_at): 무기한 opaque 토큰. 만료/회수는 Phase B.
//   - POST /api/v1/login: name+password → token.
//   - POST /api/v1/password: name+password → password_hash 설정 (append-only registry row).
//   - POST /api/v1/web/messages: 토큰 게이트, token.name == from.name 일치 후 일반 흐름.
//   - POST /api/v1/messages (외부 에이전트): 영향 0 — Q1 §6.5 hotfix 그대로 (human-bound 무서명 401).
//
// env: STOA_AUTH_HMAC_KEY (64-char lower hex ed25519 secret). 미설정 시 login/password 503.

fn _auth_hmac_key() -> Any {
    r = perform env.read("STOA_AUTH_HMAC_KEY")
    if is_error(r) { return error("STOA_AUTH_HMAC_KEY env unset") }
    k = trim(unwrap(r))
    if k == "" { return error("STOA_AUTH_HMAC_KEY env empty") }
    if not _is_lower_hex64(k) { return error("STOA_AUTH_HMAC_KEY must be 64-char lower hex") }
    return ok(k)
}

fn _hash_password(salt: Text, name: Text, password: Text) -> Any {
    k_r = _auth_hmac_key()
    if is_error(k_r) { return k_r }
    msg = join(["auth:", salt, ":", name, ":", password], "")
    return crypto_sign_ed25519(unwrap(k_r), msg)
}

// _verify_password: stored = "salt$mac". 동일 (salt, name, password)로 재계산 후 일치 비교.
fn _verify_password(stored: Text, name: Text, password: Text) -> Boolean {
    parts = split(stored, "$")
    if length(parts) != 2 { return false }
    salt = parts[0]
    expected_mac = parts[1]
    h_r = _hash_password(salt, name, password)
    if is_error(h_r) { return false }
    return unwrap(h_r) == expected_mac
}

fn _gen_salt() -> Any {
    return crypto_random_bytes(16)
}

fn _gen_session_token() -> Any {
    return crypto_random_bytes(32)
}

fn db_get_password_hash(name: Text) -> Any {
    _ensure_db()
    db = get_db_file()
    r = perform db.query(db,
        "SELECT password_hash FROM registry WHERE name = ? AND password_hash IS NOT NULL ORDER BY rowid DESC LIMIT 1",
        [name])
    if is_error(r) { return None }
    rows = unwrap(r)
    if length(rows) == 0 { return None }
    v = rows[0][0]
    if v == None { return None }
    return to_text(v)
}

// db_set_password: append-only — 새 registry row를 latest address로 INSERT, password_hash 포함.
fn db_set_password(name: Text, password_hash: Text, ts: Text) -> Any {
    _ensure_db()
    db = get_db_file()
    // 기존 latest row의 address/public_key 유지.
    cur = db_lookup(name)
    addr = ""
    pk = None
    if cur != None {
        addr = to_text(get(cur, "address"))
        pk = get(cur, "public_key")
    }
    if addr == "" {
        addr = join(["https://ail-stoa.up.railway.app/inbox/", name], "")
    }
    return perform db.execute(db,
        "INSERT INTO registry (name, address, public_key, registered_at, password_hash) VALUES (?, ?, ?, ?, ?)",
        [name, addr, pk, ts, password_hash])
}

fn db_create_session(token: Text, name: Text, ts: Text) -> Any {
    _ensure_db()
    db = get_db_file()
    return perform db.execute(db,
        "INSERT INTO sessions (token, name, created_at) VALUES (?, ?, ?)",
        [token, name, ts])
}

fn db_lookup_session(token: Text) -> Any {
    _ensure_db()
    db = get_db_file()
    r = perform db.query(db,
        "SELECT name, created_at FROM sessions WHERE token = ? ORDER BY rowid DESC LIMIT 1",
        [token])
    if is_error(r) { return None }
    rows = unwrap(r)
    if length(rows) == 0 { return None }
    return make_record([["name", to_text(rows[0][0])], ["created_at", to_text(rows[0][1])]])
}

// _bearer_token_from_req: Authorization: Bearer <tok> 또는 X-Session-Token 헤더 추출.
fn _bearer_token_from_req(req: Any) -> Text {
    h = req.headers
    auth = get(h, "Authorization")
    if auth == None { auth = get(h, "authorization") }
    if auth != None {
        a = to_text(auth)
        if starts_with(a, "Bearer ") { return slice(a, 7, length(a)) }
        if starts_with(a, "bearer ") { return slice(a, 7, length(a)) }
    }
    xst = get(h, "X-Session-Token")
    if xst == None { xst = get(h, "x-session-token") }
    if xst != None { return to_text(xst) }
    return ""
}

fn handle_login(req: Any) -> [Any] {
    k_r = _auth_hmac_key()
    if is_error(k_r) {
        return err_json(503, "login disabled (STOA_AUTH_HMAC_KEY env unset/invalid)")
    }
    parsed = parse_json(req.body)
    if is_error(parsed) { return err_json(400, "invalid JSON body") }
    body = unwrap(parsed)
    if not _is_record(body) { return err_json(400, "body must be a JSON object") }
    n = _check_str(body, "name")
    if is_error(n) { return err_json(400, unwrap_error(n)) }
    p = _check_str(body, "password")
    if is_error(p) { return err_json(400, unwrap_error(p)) }
    name = to_text(unwrap(n))
    password = to_text(unwrap(p))

    if db_lookup(name) == None {
        return err_json(401, "invalid credentials")
    }
    stored = db_get_password_hash(name)
    if stored == None {
        return err_json(401, "invalid credentials")
    }
    if not _verify_password(stored, name, password) {
        return err_json(401, "invalid credentials")
    }

    tok_r = _gen_session_token()
    if is_error(tok_r) { return err_json(500, "token generation failed") }
    token = unwrap(tok_r)
    ts = now_iso()
    db_create_session(token, name, ts)
    out = make_record([["token", token], ["name", name], ["created_at", ts]])
    return json_ok(200, msg_to_json(out))
}

fn handle_set_password(req: Any) -> [Any] {
    k_r = _auth_hmac_key()
    if is_error(k_r) {
        return err_json(503, "password set disabled (STOA_AUTH_HMAC_KEY env unset/invalid)")
    }
    parsed = parse_json(req.body)
    if is_error(parsed) { return err_json(400, "invalid JSON body") }
    body = unwrap(parsed)
    if not _is_record(body) { return err_json(400, "body must be a JSON object") }
    n = _check_str(body, "name")
    if is_error(n) { return err_json(400, unwrap_error(n)) }
    p = _check_str(body, "password")
    if is_error(p) { return err_json(400, unwrap_error(p)) }
    name = to_text(unwrap(n))
    password = to_text(unwrap(p))

    if length(password) < 8 {
        return err_json(400, "password must be 8+ chars")
    }
    if db_lookup(name) == None {
        return err_json(404, "name not registered (POST /api/v1/enter first)")
    }

    // 변경: 기존 password가 설정돼 있으면 current_password 일치 요구 (간단한 cred 보호).
    existing = db_get_password_hash(name)
    if existing != None {
        cp_v = get(body, "current_password")
        if cp_v == None or to_text(cp_v) == "" {
            return err_json(401, "current_password required to change existing password")
        }
        if not _verify_password(existing, name, to_text(cp_v)) {
            return err_json(401, "current_password mismatch")
        }
    }

    salt_r = _gen_salt()
    if is_error(salt_r) { return err_json(500, "salt generation failed") }
    salt = unwrap(salt_r)
    h_r = _hash_password(salt, name, password)
    if is_error(h_r) { return err_json(500, "hash failed") }
    stored = join([salt, "$", unwrap(h_r)], "")

    ts = now_iso()
    db_set_password(name, stored, ts)
    out = make_record([["name", name], ["password_set", true], ["registered_at", ts]])
    return json_ok(201, msg_to_json(out))
}

// _verify_session_for: 헤더 토큰 추출 + 세션 lookup + name 일치 확인. 통과 시 ok(name).
fn _verify_session_for(req: Any, expected_name: Text) -> Any {
    tok = _bearer_token_from_req(req)
    if tok == "" { return error("session token required") }
    sess = db_lookup_session(tok)
    if sess == None { return error("invalid session token") }
    sname = to_text(get(sess, "name"))
    if sname != expected_name { return error("token name mismatch") }
    return ok(sname)
}

fn handle_post_web_message(req: Any) -> [Any] {
    parsed = parse_json(req.body)
    if is_error(parsed) { return err_json(400, "invalid JSON body") }
    body = unwrap(parsed)
    if not _is_record(body) { return err_json(400, "body must be a JSON object") }
    fr = get(body, "from")
    if fr == None or not _is_record(fr) {
        return err_json(400, "from must be a record with name and address")
    }
    fn_v = get(fr, "name")
    if fn_v == None { return err_json(400, "from.name required") }
    from_name = to_text(fn_v)

    v = _verify_session_for(req, from_name)
    if is_error(v) { return err_json(401, unwrap_error(v)) }

    return handle_post_message(req)
}

// ---------- alias handlers ----------

fn handle_add_alias(req: Any) -> [Any] {
    parsed = parse_json(req.body)
    if is_error(parsed) { return err_json(400, "invalid JSON body") }
    body = unwrap(parsed)
    a = _check_str(body, "alias")
    if is_error(a) { return err_json(400, unwrap_error(a)) }
    c = _check_str(body, "canonical")
    if is_error(c) { return err_json(400, unwrap_error(c)) }
    alias = to_text(unwrap(a))
    canonical = to_text(unwrap(c))
    // canonical이 registry에 있어야 함 — 유령 alias 방지
    if db_lookup(canonical) == None {
        return err_json(400, join(["canonical '", canonical, "' is not registered"], ""))
    }
    ts = now_iso()
    db_add_alias(alias, canonical, ts)
    body_out = make_record([["alias", alias], ["canonical", canonical], ["bound_at", ts]])
    return json_ok(201, msg_to_json(body_out))
}

fn handle_list_aliases(req: Any) -> [Any] {
    items = db_list_aliases()
    body = make_record([["count", length(items)], ["aliases", items]])
    return json_ok(200, msg_to_json(body))
}

// ---------- agent entry point ----------
//
// 에이전트가 한 번의 호출로 입장한다:
//   1) 이름 + 주소 등록 (address 생략 시 stoa_origin/inbox/<name>로 자동)
//   2) 인박스 스냅샷 수신
//   3) 세 원칙 + API 안내문 수신
//
// POST /api/v1/enter  body {name, address?}
// GET  /api/v1/enter            안내 (사람용 — 어떻게 들어오는지)

fn _stoa_origin(req: Any) -> Text {
    h = req.headers
    host = get(h, "Host")
    if host == None { host = get(h, "host") }
    if host == None { host = "localhost:8090" }
    host_t = to_text(host)
    proto = get(h, "X-Forwarded-Proto")
    proto_t = "https"
    if proto != None { proto_t = to_text(proto) }
    if starts_with(host_t, "localhost") or starts_with(host_t, "127.") {
        proto_t = "http"
    }
    origin = join([proto_t, "://", host_t], "")
    // 사이클 9 fallback B — 첫 request의 origin을 state에 latch.
    // autonomous tick path(_autonomous_act → _get_self_origin)가 request 문맥
    // 없이 state read로 회수 → STOA_SELF_ORIGIN env 의존 제거. once-only flag로
    // 매 request마다 sqlite write 누적 회피 (`db.initialized` 패턴 동형).
    flag_r = perform state.read("server.self_origin_latched")
    latched = false
    if not is_error(flag_r) {
        if unwrap(flag_r) == 1 { latched = true }
    }
    if not latched {
        perform state.write("server.self_origin", origin)
        perform state.write("server.self_origin_latched", 1)
    }
    return origin
}

fn handle_enter(req: Any) -> [Any] {
    if req.method == "GET" {
        body = "에이전트 진입점 (Stoa entry point)\n\nPOST /api/v1/enter\n  body: {\"name\": \"<your-name>\", \"address\": \"<optional listener URL>\"}\n  → 등록 + 인박스 스냅샷 + 세 원칙 안내\n\nname만 있으면 address는 자동: <stoa_origin>/inbox/<name>\n같은 이름으로 다시 enter하면 latest wins (append-only).\n\n세 원칙:\n  1) 누가 누구에게 — from {name, address} + to [{name, address}, ...]\n  2) 받기/주기      — POST 받고, 각 수신자 address로 능동 push\n  3) 쌓이기만       — INSERT only, UPDATE/DELETE 없음\n"
        return [200, "text/plain; charset=utf-8", body]
    }

    parsed = parse_json(req.body)
    if is_error(parsed) { return err_json(400, "invalid JSON body") }
    body = unwrap(parsed)

    n = _check_str(body, "name")
    if is_error(n) { return err_json(400, unwrap_error(n)) }
    name = to_text(unwrap(n))

    addr_v = get(body, "address")
    address = ""
    if addr_v != None and to_text(addr_v) != "" {
        address = to_text(addr_v)
    } else {
        address = join([_stoa_origin(req), "/inbox/", name], "")
    }

    g = _register_gate(name, address, body)
    if get(g, "ok") == false {
        return err_json(get(g, "code"), to_text(get(g, "msg")))
    }
    ts = to_text(get(g, "registered_at"))
    inbox = db_inbox_for(name, 20, "")

    welcome = make_record([
        ["name", name],
        ["address", address],
        ["public_key", get(g, "public_key")],
        ["registered_at", ts],
        ["inbox_count", length(inbox)],
        ["recent_letters", inbox],
        ["principles", [
            "1) 누가 누구에게 — from + to 모든 편지에 명시",
            "2) 받기/주기 — POST로 받고, 각 수신자 address로 능동 push",
            "3) 쌓이기만 — INSERT only. 편지도 registry도 latest wins"
        ]],
        ["api", make_record([
            ["send", "POST /api/v1/messages  body {from:{name,address}, to:[...], content}"],
            ["inbox", "GET /api/v1/messages?to=<your-name>"],
            ["all", "GET /api/v1/messages"],
            ["lookup", "GET /api/v1/agents/<name>"],
            ["update_address", "POST /api/v1/agents body {name, address}"]
        ])],
        ["welcome", join(["환영해, ", name, ". Stoa에 입장했어. 인박스에 ", to_text(length(inbox)), "통 대기 중."], "")]
    ])
    return json_ok(201, msg_to_json(welcome))
}

// ---------- web UI ----------

fn handle_ui(req: Any) -> [Any] {
    css = "body{font-family:Georgia,serif;background:#fafaf8;color:#222;max-width:760px;margin:0 auto;padding:1rem 1.2rem;line-height:1.5}h1{font-size:1.5rem;border-bottom:2px solid #222;padding-bottom:.5rem;margin:0 0 .6rem}h2{font-size:1.1rem;margin:1.2rem 0 .6rem}nav{margin:.6rem 0 1rem;font-size:.9rem}nav a{margin-right:.8rem;color:#444;cursor:pointer;border-bottom:1px dashed #888}nav a.active{color:#000;border-bottom:1px solid #000;font-weight:bold}.letter{background:#fff;border-left:3px solid #888;padding:.7rem 1rem;margin-bottom:.6rem}.letter .meta{font-size:.8rem;color:#666}.letter .body{margin-top:.3rem;white-space:pre-wrap}form.card{background:#fff;padding:1rem;border:1px solid #ddd;margin-bottom:1rem}label{display:block;font-size:.8rem;color:#555;margin:.6rem 0 .2rem}input,textarea{width:100%;padding:.5rem;font:inherit;border:1px solid #aaa;box-sizing:border-box}textarea{min-height:5rem;resize:vertical}button{background:#222;color:#fff;border:0;padding:.5rem 1rem;cursor:pointer;font:inherit;margin-top:.4rem}button.ghost{background:#fff;color:#222;border:1px solid #aaa;margin:.2rem .3rem 0 0}.muted{color:#666;font-size:.85rem}.err{color:#a22}.ok{color:#272}"

    js = join([
        "const API=location.origin;",
        "const E=(tag,p={},...c)=>{const e=document.createElement(tag);for(const k in p){if(k==='on')for(const v in p.on)e.addEventListener(v,p.on[v]);else if(k==='class')e.className=p[k];else e.setAttribute(k,p[k]);}for(const x of c)e.append(x instanceof Node?x:document.createTextNode(x));return e;};",
        "const me=()=>localStorage.getItem('stoa_user')||null;",
        "const setMe=n=>n?localStorage.setItem('stoa_user',n):localStorage.removeItem('stoa_user');",
        "const tok=()=>localStorage.getItem('stoa_token')||null;",
        "const setTok=t=>t?localStorage.setItem('stoa_token',t):localStorage.removeItem('stoa_token');",
        "async function api(p,o={}){const r=await fetch(API+p,o);const t=await r.text();let j;try{j=JSON.parse(t);}catch{j={_raw:t};}if(!r.ok)throw new Error(j.error||('HTTP '+r.status));return j;}",
        "function authHeaders(){const t=tok();return t?{'Authorization':'Bearer '+t}:{};}",
        "function L(m){const to=(m.to||[]).map(t=>t.name).join(', ');return E('div',{class:'letter'},E('div',{class:'meta'},`${m.from&&m.from.name||'?'} → ${to} · ${m.created_at||''} · ${m.id}`),E('div',{class:'body'},m.content||''));}",

        "async function viewWelcome(){const app=document.getElementById('app');app.innerHTML='';",
        "app.append(E('p',{class:'muted'},'편지를 주고받는 곳. 새 계정을 만들거나 기존 이름+비밀번호로 들어와.'));",
        "app.append(E('h2',{},'🆕 새 계정 만들기'));",
        "const f=E('form',{class:'card'});const n=E('input',{name:'name',placeholder:'이름 (예: alice)',required:'required'});const a=E('input',{name:'address',placeholder:'주소 (예: https://you.example/inbox)',required:'required'});const pw=E('input',{type:'password',name:'password',placeholder:'비밀번호 (8자 이상)',required:'required',minlength:'8'});const m=E('div',{class:'muted'});",
        "f.append(E('label',{},'이름'),n,E('label',{},'주소 (Stoa가 너에게 push할 곳)'),a,E('label',{},'비밀번호'),pw,E('button',{type:'submit'},'만들고 들어가기'),m);",
        "f.addEventListener('submit',async e=>{e.preventDefault();m.className='muted';m.textContent='등록 중...';try{const nm=n.value.trim();await api('/api/v1/agents',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name:nm,address:a.value.trim()})});await api('/api/v1/password',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name:nm,password:pw.value})});const r=await api('/api/v1/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name:nm,password:pw.value})});setTok(r.token);setMe(nm);render();}catch(e){m.className='err';m.textContent=e.message;}});",
        "app.append(f);",
        "app.append(E('h2',{},'🚪 들어오기'));",
        "const card=E('form',{class:'card'});const ln=E('input',{name:'name',placeholder:'이름',required:'required'});const lp=E('input',{type:'password',name:'password',placeholder:'비밀번호',required:'required'});const lm=E('div',{class:'muted'});const btn=E('button',{type:'submit'},'로그인');",
        "card.append(E('label',{},'이름'),ln,E('label',{},'비밀번호'),lp,btn,lm);",
        "card.addEventListener('submit',async ev=>{ev.preventDefault();lm.className='muted';lm.textContent='로그인 중...';try{const r=await api('/api/v1/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name:ln.value.trim(),password:lp.value})});setTok(r.token);setMe(ln.value.trim());render();}catch(e){lm.className='err';lm.textContent=e.message;}});",
        "app.append(card);}",

        "async function viewInbox(){const app=document.getElementById('app');app.innerHTML='';app.append(E('h2',{},'📥 내 인박스'));try{const d=await api('/api/v1/messages?to='+encodeURIComponent(me()));if(!d.messages.length)app.append(E('p',{class:'muted'},'아직 받은 편지 없음.'));else for(const m of d.messages)app.append(L(m));}catch(e){app.append(E('p',{class:'err'},e.message));}}",

        "async function viewAll(){const app=document.getElementById('app');app.innerHTML='';app.append(E('h2',{},'🌐 모두의 편지'));try{const d=await api('/api/v1/messages');if(!d.messages.length)app.append(E('p',{class:'muted'},'아직 편지 없음.'));else for(const m of d.messages)app.append(L(m));}catch(e){app.append(E('p',{class:'err'},e.message));}}",

        "async function viewProfile(){const app=document.getElementById('app');app.innerHTML='';app.append(E('h2',{},'👤 내 정체'));try{const d=await api('/api/v1/agents/'+encodeURIComponent(me()));app.append(E('p',{},`이름: ${d.name}`),E('p',{},`주소: ${d.address}`),E('p',{class:'muted'},`등록: ${d.registered_at}`));}catch(e){app.append(E('p',{class:'err'},'registry에 미등록 — 주소를 저장해줘.'));}",
        "const f=E('form',{class:'card'});const a=E('input',{placeholder:'새 주소',required:'required'});const m=E('div',{class:'muted'});f.append(E('label',{},'주소 변경'),a,E('button',{},'저장'),m);",
        "f.addEventListener('submit',async e=>{e.preventDefault();m.className='muted';m.textContent='저장 중...';try{await api('/api/v1/agents',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name:me(),address:a.value.trim()})});m.className='ok';m.textContent='저장됨';}catch(e){m.className='err';m.textContent=e.message;}});",
        "app.append(f);}",

        "async function viewCompose(){const app=document.getElementById('app');app.innerHTML='';app.append(E('h2',{},'✍️ 편지 쓰기'));",
        "if(!tok()){app.append(E('p',{class:'err'},'세션 만료 — 다시 로그인해줘.'));return;}",
        "const f=E('form',{class:'card'});const to=E('input',{placeholder:'받는 사람 이름들 (쉼표로 구분)',required:'required'});const c=E('textarea',{placeholder:'내용',required:'required'});const m=E('div',{class:'muted'});",
        "f.append(E('label',{},'받는 사람'),to,E('label',{},'내용'),c,E('button',{},'보내기'),m);",
        "f.addEventListener('submit',async e=>{e.preventDefault();m.className='muted';m.textContent='주소 조회 후 발송...';try{const names=to.value.split(',').map(s=>s.trim()).filter(Boolean);const rs=[];for(const n of names){const r=await api('/api/v1/agents/'+encodeURIComponent(n));rs.push({name:r.name,address:r.address});}const meA=await api('/api/v1/agents/'+encodeURIComponent(me()));await api('/api/v1/web/messages',{method:'POST',headers:Object.assign({'Content-Type':'application/json'},authHeaders()),body:JSON.stringify({from:{name:meA.name,address:meA.address},to:rs,content:c.value})});m.className='ok';m.textContent='발송 완료.';to.value='';c.value='';}catch(e){m.className='err';m.textContent=e.message;}});",
        "app.append(f);}",

        "function render(){document.body.innerHTML='';document.body.append(E('h1',{},'📮 Stoa'));if(!me()){document.body.append(E('div',{id:'app'}));return viewWelcome();}const nav=E('nav');",
        "const mk=(label,fn)=>{const a=E('a',{},label);a.addEventListener('click',()=>{document.querySelectorAll('nav a').forEach(x=>x.classList.remove('active'));a.classList.add('active');fn();});return a;};",
        "nav.append(E('span',{},`안녕, ${me()} · `),mk('📥 인박스',viewInbox),mk('🌐 모두의 편지',viewAll),mk('✍️ 편지 쓰기',viewCompose),mk('👤 정체',viewProfile),mk('🚪 로그아웃',()=>{setMe(null);setTok(null);render();}));",
        "document.body.append(nav,E('div',{id:'app'}));viewInbox();}",

        "render();"
    ], "")

    html = join([
        "<!doctype html><html lang='ko'><head><meta charset='utf-8'><meta name='viewport' content='width=device-width,initial-scale=1'><title>Stoa</title><style>",
        css,
        "</style></head><body><h1>📮 Stoa</h1><div id='app'></div><script>",
        js,
        "</script></body></html>"
    ], "")
    return [200, "text/html", html]
}

// ---------- routing ----------

fn route(req: Any) -> [Any] {
    method = req.method
    path = req.path

    if method == "GET" and path == "/" {
        return handle_ui(req)
    }
    if method == "GET" and path == "/ui" {
        return handle_ui(req)
    }
    if method == "GET" and path == "/api/v1/health" {
        return handle_health(req)
    }
    if method == "POST" and path == "/api/v1/messages" {
        return handle_post_message(req)
    }
    if method == "POST" and path == "/api/v1/web/messages" {
        return handle_post_web_message(req)
    }
    if method == "POST" and path == "/api/v1/login" {
        return handle_login(req)
    }
    if method == "POST" and path == "/api/v1/password" {
        return handle_set_password(req)
    }
    if method == "GET" and path == "/api/v1/messages" {
        return handle_list_inbox(req)
    }
    if method == "GET" and starts_with(path, "/api/v1/messages/") {
        msg_id = slice(path, 17, length(path))
        return handle_get_message(req, msg_id)
    }
    // RFC-004 §4 — Phase A endpoints (cursor + ack).
    if method == "GET" and path == "/api/v1/inbox" {
        return handle_inbox_get(req)
    }
    if method == "POST" and path == "/api/v1/inbox/ack" {
        return handle_inbox_ack(req)
    }
    if method == "GET" and path == "/api/v1/debug/discord" {
        return handle_debug_discord(req)
    }
    if method == "POST" and path == "/api/v1/discord" {
        return handle_discord(req)
    }
    if method == "POST" and path == "/api/v1/enter" {
        return handle_enter(req)
    }
    if method == "GET" and path == "/api/v1/enter" {
        return handle_enter(req)
    }
    if method == "POST" and path == "/api/v1/agents" {
        return handle_register(req)
    }
    if method == "POST" and path == "/api/v1/aliases" {
        return handle_add_alias(req)
    }
    if method == "GET" and path == "/api/v1/aliases" {
        return handle_list_aliases(req)
    }
    if method == "GET" and path == "/api/v1/agents" {
        return handle_list_registry(req)
    }
    if method == "GET" and starts_with(path, "/api/v1/agents/") {
        name = slice(path, 15, length(path))
        return handle_lookup(req, name)
    }
    if method == "POST" and path == "/api/v1/platform-keys" {
        return handle_register_platform_key(req)
    }
    if method == "GET" and path == "/api/v1/platform-keys" {
        return handle_list_platform_keys(req)
    }
    if method == "GET" and starts_with(path, "/api/v1/platform-keys/") {
        id = slice(path, 22, length(path))
        return handle_lookup_platform_key(req, id)
    }
    // 4차 다운 hotfix (d) (2026-05-12) — `/inbox/<name>` 경로 진단.
    // Mneme team이 옛 flat endpoint(`/inbox/<name>`)로 polling/push 중 (Stoa#6
    // envelope schema 마이그레이션 lag). default "not found"는 무엇이 잘못인지
    // 침묵 → 호출자 로그에서 즉시 정정 trigger 0. 본 path 한정 명시적 메시지로
    // 자기 정정 유도.
    if starts_with(path, "/inbox/") {
        return err_json(404,
            "endpoint /inbox/<name> deprecated. use POST /api/v1/messages with envelope schema (from/to/content); poll via GET /api/v1/messages?to=<name>&since_id=<n>. see docs/migrations/flat-to-envelope.md.")
    }
    return err_json(404, "not found")
}

// ============================================================================
// RFC-004 Phase B — autonomous main loop (observe → reason → act)
// ============================================================================
//
// AIL `ail run` + `evolve` 환경에서 schedule.every가 작동 (v1.72.2+). on_birth
// 시점에 cadence 등록, on_tick이 매 N초 발화. RFC-004 §3·§6.2 본 구현.

// _emit_self_letter_body: _emit_self_letter의 INSERT 두 건 본문. db.execute가
// effect 예외 raise할 수 있어 별도 함수로 분리 — try 표현이 단일 expression을
// 감싸므로 (block form `try { ... }` 미지원, on_tick / _on_tick_body 동일 패턴).
//
// Phase C C1 (사이클 9) — signature/nonce 인자 추가. 두 인자 모두 None일 수
// 있고(this lifetime이 self.secret 미보유, 옛 self-row 위에서 부팅한 인스턴스),
// 그 경우 db_insert_letter가 NULL 컬럼으로 INSERT — 옛 Phase B 무서명 emit과
// 동형. 본 실패 시 폴백 path가 자연 유지.
fn _emit_self_letter_body(msg_id: Text, ts: Text, to_name: Text, to_addr: Text, content: Text, signature: Any, nonce: Any) -> Any {
    db_insert_letter(msg_id, "Stoa-Stoa", "stoa://self", content, ts, signature, nonce)
    db_insert_recipient(msg_id, to_name, to_addr)
    return None
}

// _emit_self_letter: from=Stoa-Stoa 자기 letter 1건 INSERT. msg_id 자동 할당,
// recipient row 1건. 응답 0 (autonomous emit, response 회수 무관).
//
// Phase C C1 (사이클 9) — ed25519 자기서명. RFC-004 §5.3 + Walter msg_48 Q2:
// 별도 self-letter canonical 형식 없음, RFC-001 §6.1 그대로 재사용.
//   nonce = crypto_random_bytes(16) → 32-char hex.
//   canonical = canonical_letter("Stoa-Stoa", "stoa://self", [{to_name,to_addr}],
//                                content, ts, nonce).
//   signature = crypto_sign_ed25519(self.secret_key_hex, canonical).
// 수신측 검증: registry self-row `Stoa-Stoa`.public_key로 crypto_verify_ed25519.
//
// **현 Phase 한계**: self.secret_key_hex는 `_ensure_self_genesis`가 *이번 라이프
// 타임에 keypair 생성*했을 때만 process state에 살아 있음. Railway 재시작 후
// self-row 이미 존재 분기에서는 secret 없음 → graceful 무서명 fallback (None 두
// 인자, db NULL). Phase D(vault·외부 KMS) land 후 항상 서명 가능. 본 단계는
// genesis lifetime에서만 서명 — AC-C2 시나리오는 fresh 인스턴스라 covered.
//
// 4차 다운 hotfix (b) (2026-05-12) — `db_insert_letter`/`db_insert_recipient`가
// `perform db.execute`을 직접 호출하는데 SQLite lock contention·disk full 등에서
// effect 예외 raise 가능. autonomous tick path(idle_ping·escalate alert·final)에서
// 발생하면 on_tick outer attempt(a)가 흡수해 evolve runtime은 안 죽지만, stack을
// 위로 거슬러 빠져나가는 동안 `_autonomous_observe`의 last_tick_at advance가
// 누락될 자리는 (a)가 catch trace에서 보장. 본 (b)는 그 이전 단계 — emit 자체가
// 흡수해 후속 sibling 동작(다른 subscriber pump 등)이 한 INSERT 실패로 전체
// 차단되지 않게.
// 반환값은 msg_id Text — 실패 시 빈 문자열 ("")로 굳혀 호출자가 자취 인식.
fn _emit_self_letter(to_name: Text, to_addr: Text, content: Text) -> Text {
    _ensure_db()
    _ensure_self_genesis()
    msg_id = make_id()
    ts = now_iso()

    // self-sign 시도 — secret 보유 시에만 서명, 미보유 시 None 두 인자로 무서명
    // emit (Phase B 동작 보존 + Railway 재시작 분기 graceful).
    sig_arg = None
    nonce_arg = None
    sk_r = perform state.read("self.secret_key_hex")
    if not is_error(sk_r) {
        sk = to_text(unwrap(sk_r))
        if sk != "" {
            nonce_r = crypto_random_bytes(16)
            if not is_error(nonce_r) {
                nonce_hex = unwrap(nonce_r)
                if nonce_hex != "" {
                    recipients = [make_record([
                        ["name", to_name],
                        ["address", to_addr]
                    ])]
                    canon = canonical_letter("Stoa-Stoa", "stoa://self", recipients, content, ts, nonce_hex)
                    sig_r = crypto_sign_ed25519(sk, canon)
                    if not is_error(sig_r) {
                        sig_hex = unwrap(sig_r)
                        if sig_hex != "" {
                            sig_arg = sig_hex
                            nonce_arg = nonce_hex
                        }
                    }
                }
            }
        }
    }

    r = attempt {
        try _emit_self_letter_body(msg_id, ts, to_name, to_addr, content, sig_arg, nonce_arg)
        try error("emit_self_letter failed")
    }
    if is_error(r) { return "" }
    return msg_id
}

// _admin_address: registry에서 Stoa-Admin address 회수 (escalate·idle_ping 송신
// 대상). registry 부재 시 fallback 빈 문자열 — 호출자가 빈 문자열이면 emit skip.
fn _admin_address() -> Text {
    row = db_lookup("Stoa-Admin")
    if row == None { return "" }
    return to_text(get(row, "address"))
}

// 상태 추적은 SQLite `delivery_log` 테이블에 — AIL 1.72.2 state.* 파일 기반 IO
// 가 pump의 빠른 read/write 사이클에서 race-prone (state.has가 file 존재시에도
// false 반환되는 자리 발견). DB는 atomic INSERT/SELECT로 신뢰.
//
//   delivery_log (name TEXT, msg_id TEXT, status TEXT, attempts INT, last_at TEXT,
//                 PRIMARY KEY (name, msg_id))
//   status: "delivered" | "failed" | "skipped" | "pending"
//   PRIMARY KEY로 멱등 INSERT OR REPLACE.
fn _ensure_delivery_log() -> Any {
    db = get_db_file()
    perform db.execute(db,
        "CREATE TABLE IF NOT EXISTS delivery_log (name TEXT NOT NULL, msg_id TEXT NOT NULL, status TEXT NOT NULL, attempts INTEGER NOT NULL, last_at TEXT NOT NULL, PRIMARY KEY (name, msg_id))")
    return None
}

// _delivery_pending: name 앞 letter 중 *terminal status 안 가진* 것만 반환 (push
// 대상). delivery_log JOIN으로 SQL level filter — AIL 측 비교 0.
fn _delivery_pending(name: Text, limit: Number) -> [Any] {
    _ensure_delivery_log()
    db = get_db_file()
    r = perform db.query(db,
        "SELECT l.id, l.from_name, l.from_address, l.content, l.created_at, l.signature, l.nonce FROM letters l JOIN recipients rcp ON rcp.letter_id = l.id WHERE rcp.name = ? AND l.id NOT IN (SELECT msg_id FROM delivery_log WHERE name = rcp.name AND status IN ('delivered','skipped','failed')) ORDER BY l.rowid ASC LIMIT ?",
        [name, limit])
    if is_error(r) { return [] }
    out = []
    for row in unwrap(r) {
        out = append(out, _row_to_envelope(row))
    }
    return out
}

fn _delivery_attempts(name: Text, mid: Text) -> Number {
    _ensure_delivery_log()
    db = get_db_file()
    r = perform db.query(db,
        "SELECT attempts FROM delivery_log WHERE name = ? AND msg_id = ? LIMIT 1",
        [name, mid])
    if is_error(r) { return 0 }
    rows = unwrap(r)
    if length(rows) == 0 { return 0 }
    return rows[0][0]
}

fn _delivery_upsert(name: Text, mid: Text, status: Text, attempts: Number, ts: Text) -> Any {
    _ensure_delivery_log()
    db = get_db_file()
    perform db.execute(db,
        "INSERT OR REPLACE INTO delivery_log (name, msg_id, status, attempts, last_at) VALUES (?, ?, ?, ?, ?)",
        [name, mid, status, attempts, ts])
    return None
}

// _maybe_escalate: per-letter 시도 횟수에 따라 alert / final escalate letter
// 발신. dedup은 `delivered.<>.<>.status` 기록으로 — alert가 한 번 fire되면
// status는 여전히 "failed" 누적, 후속 fail에서 attempts == retry_max 도달 시
// final fire. alert/final 발사 자취는 letter 자체 (Admin 인박스에 박힘).
fn _maybe_escalate(name: Text, mid: Text, attempts: Number) -> Any {
    // Stoa-Admin은 escalation 채널 자체 — 자기 자신을 escalate 시 loop. 차단.
    if name == "Stoa-Admin" { return None }
    admin_addr = _admin_address()
    if admin_addr == "" { return None }
    after = _get_escalate_after_fail()
    retry_max = _get_deliver_retry_max()
    // alert 단계: attempts가 ESCALATE_AFTER_FAIL 도달한 *그 시점*에 한 번.
    if attempts == after and after < retry_max {
        body = join([
            "subject: escalate — ", name, " 전달 ", to_text(after), "회 실패 (alert)\n",
            "priority: high\n",
            "---\n\n",
            "subscriber=", name, " mid=", mid, " attempts=", to_text(attempts), "\n",
            "RFC-004 §3.4 escalate alert. retry는 retry_max=", to_text(retry_max), " 까지 계속.\n",
            "\n---END-OF-CONVERSATION---"
        ], "")
        _emit_self_letter("Stoa-Admin", admin_addr, body)
        return None
    }
    // final 단계: attempts가 RETRY_MAX 도달 시 한 번. status도 "failed"로 굳힘.
    if attempts == retry_max {
        body = join([
            "subject: escalate — ", name, " final-fail (N=max)\n",
            "priority: high\n",
            "---\n\n",
            "subscriber=", name, " mid=", mid, " attempts=", to_text(attempts), "\n",
            "RFC-004 §3.4 escalate final. delivered.<>.status='failed' 굳힘. retry 중단.\n",
            "\n---END-OF-CONVERSATION---"
        ], "")
        _emit_self_letter("Stoa-Admin", admin_addr, body)
        return None
    }
    return None
}

// _pump_subscriber: 한 subscriber 앞 미전달 letter 시도 (deliver / skip).
// cursor 위치는 advance 안 함 (§4.2 — 클라이언트 ack로만 advance, push는
// `delivered.*` 기록만). 이미 status == "delivered"|"failed"|"skipped"인
// letter는 skip (idempotent). 자기 host address는 issue#3 doctrine 정합으로
// status="skipped" + push 시도 0.
fn _pump_subscriber(sub: Any, self_origin: Text) -> Any {
    name = to_text(get(sub, "name"))
    addr = to_text(get(sub, "address"))
    // self-row Stoa-Stoa는 pump 대상 0. Stoa-Admin은 escalation 채널 자체 —
    // 자기 인박스에 박힌 escalate letter를 pump가 또 push하면 (1) 의미 0 (Admin은
    // 자기 polling으로 회수), (2) admin address가 종종 dummy/non-routable (test
    // fixture, 운영 시 admin이 polling subscriber)라 push가 hung → on_tick budget
    // 초과 → escalate 자체 차단되는 deadlock. Admin pump 차단으로 본 cycle 끊음.
    if name == "Stoa-Stoa" { return None }
    if name == "Stoa-Admin" { return None }
    msgs = _delivery_pending(name, 50)
    retry_max = _get_deliver_retry_max()
    ts = now_iso()
    for env_obj in msgs {
        mid = to_text(get(env_obj, "id"))
        // self-host skip — push 시도 0, status="skipped".
        if _is_self_host(addr, self_origin) {
            _delivery_upsert(name, mid, "skipped", 0, ts)
            continue
        }
        prev_attempts = _delivery_attempts(name, mid)
        if prev_attempts >= retry_max { continue }
        attempt_n = prev_attempts + 1
        // push 시도 (_push_one_fast: timeout=1s, autonomous tick budget 친화).
        push_r = _push_one_fast(addr, env_obj)
        if is_error(push_r) {
            if attempt_n >= retry_max {
                _delivery_upsert(name, mid, "failed", attempt_n, ts)
            } else {
                _delivery_upsert(name, mid, "pending", attempt_n, ts)
            }
            _maybe_escalate(name, mid, attempt_n)
        } else {
            _delivery_upsert(name, mid, "delivered", attempt_n, ts)
        }
    }
    return None
}

// _autonomous_observe: §3.2 — health.last_tick_at 갱신 + 다음 행동을 위한
// observation 자리 (현재는 last_tick_at 갱신만, autonomous tick 가시 surface).
fn _autonomous_observe() -> Any {
    perform state.write("health.last_tick_at", now_iso())
    return None
}

// _autonomous_act: §3.3·§3.4 — registered subscriber 모두에 대해 pump 실행 +
// idle_ping 검사. self-row Stoa-Stoa는 pump 대상 0.
fn _autonomous_act() -> Any {
    self_origin = _get_self_origin()
    subs = db_list_registry()
    for s in subs {
        _pump_subscriber(s, self_origin)
    }
    // idle_ping: IDLE_PING_INTERVAL_S 경과 시 한 번. 자기 last_idle_ping_at unix
    // 와 현재 unix를 SQL level에서 비교해 boolean 결과를 받는다 — AIL Number
    // 비교 자리 우회. 먼저 emit 가능 시점인지 SQL로 확인 후 emit.
    interval = _get_idle_ping_interval_s()
    last_iso_r = perform state.read("health.last_idle_ping_at")
    last_iso = ""
    if not is_error(last_iso_r) { last_iso = to_text(unwrap(last_iso_r)) }
    db = get_db_file()
    // SQL: SELECT 1 WHERE strftime('%s','now') - <last_unix> >= <interval>
    // last_iso가 빈 문자열이면 "1970-01-01" 시작점 가정 — 즉시 fire.
    cmp_iso = last_iso
    if cmp_iso == "" { cmp_iso = "1970-01-01T00:00:00Z" }
    cmp_r = perform db.query(db,
        "SELECT 1 WHERE CAST(strftime('%s','now') AS INTEGER) - CAST(strftime('%s', ?) AS INTEGER) >= ?",
        [cmp_iso, interval])
    if is_error(cmp_r) { return None }
    cmp_rows = unwrap(cmp_r)
    if length(cmp_rows) == 0 { return None }
    // 발화 시점 도달.
    admin_addr = _admin_address()
    if admin_addr == "" { return None }
    body = join([
        "subject: ping — alive @ ", now_iso(), "\n",
        "priority: normal\n",
        "---\n\n",
        "RFC-004 §3.4 idle_ping. interval=", to_text(interval), "s.\n",
        "\n---END-OF-CONVERSATION---"
    ], "")
    _emit_self_letter("Stoa-Admin", admin_addr, body)
    perform state.write("health.last_idle_ping_at", now_iso())
    return None
}

// on_birth: agentic runtime 첫 부팅 hook. schedule.every 등록 + DB 초기화 + 자기
// genesis 보장. on_genesis 보다 on_birth가 *항상* 호출 (testament 인계 분기 0).
fn on_birth() -> Any {
    _ensure_db()
    sec = _get_tick_sec()
    perform schedule.every(sec)
    return None
}

// _on_tick_body: on_tick의 실제 본문. outer attempt+try가 perform 예외를
// 흡수할 수 있게 별도 함수로 분리 (try 표현이 단일 expression을 감싸므로).
fn _on_tick_body() -> Any {
    _autonomous_observe()
    _autonomous_act()
    return None
}

// on_tick: 매 schedule.every 주기에 발화. observe → act. reason은 act 안에 흡수
// (각 pump이 자기 분류 — RFC §3.3 행동 후보 직접 반영).
//
// 4차 다운 hotfix (2026-05-12) — sub-call 안 perform 예외(self-loop urllib
// timeout 등)가 evolve runtime으로 새 `[evolve] on_tick failed` 누적 → 메모리
// leak → OOM kill. outer attempt+try로 어떤 perform 예외도 흡수해 evolve
// runtime이 unhandled로 받지 않게 한다. (b)(c)(d)는 후속 commit 분리.
//
// AC-B5: 흡수 경로에서도 `health.last_tick_at`를 advance시켜 autonomous loop
// 가동 신호를 유지 (`_autonomous_observe`가 도달 전 실패해도 alive surface).
// _push_one_fast/_emit_self_letter의 effect 예외 클래스 누락은 (b) 트랙.
fn on_tick(state: Any) -> Any {
    attempt {
        try _on_tick_body()
        try perform state.write("health.last_tick_at", now_iso())
    }
    return None
}

evolve stoa {
    listen: 8090
    effects: [http.respond, http.post_json, db.execute, db.query, clock.now, state.read, state.write, state.has, env.read, schedule.every]
    metric: error_rate
    when request_received(req) {
        result = route(req)
        perform http.respond(get(result, 0), get(result, 1), get(result, 2))
    }
    rollback_on: error_rate > 0.9
    history: keep_last 100
}
